@*
  ProgramDetail.razor
  Propósito: Mostrar detalles de un programa, incluyendo metas financieras y/o voluntariado.
*@
@page "/programs/{Id:int}"
@using Microsoft.EntityFrameworkCore
@using ProyectoSocioEconomico.Application.Interfaces
@using ProyectoSocioEconomico.Domain.Entities
@using ProyectoSocioEconomico.Infrastructure.Data
@using ProyectoSocioEconomico.WebUI.Services
@using System.Globalization
@inject IProgramaService ProgramaService
@inject IUsuarioService UsuarioService
@inject CustomAuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation
@inject AppDbContext DbContext

@if (Program == null)
{
    <div class="bulma-container">
        <p>Cargando detalles del programa...</p>
    </div>
}
else
{
    var totalRecaudado = GetTotalRecaudado(Program);
    var totalVoluntarios = GetTotalVoluntariosActivos(Program);
    var progresoFinanciero = CalcularPorcentaje(Program.MetaFinanciera, totalRecaudado);
    var progresoVoluntariado = CalcularPorcentaje(Program.MetaVoluntarios, totalVoluntarios);
    var progresoPrincipal = GetProgresoPrincipal(Program, progresoFinanciero, progresoVoluntariado);
    var puedeDonar = ProgramAcceptsDonations(Program) && IsProgramActive(Program);
    var puedeUnirse = ProgramAcceptsVolunteers(Program) &&
                      IsProgramActive(Program) &&
                      !UserIsAlreadyVolunteer &&
                      !VolunteerCapacityReached(Program, totalVoluntarios);

    <div class="cd-page">
        <div class="cd-layout">
            <main class="cd-main">
                <article class="cd-hero-card">
                    <div class="cd-hero-card__image-wrap">
                        @if (!string.IsNullOrEmpty(Program.ImagenUrl))
                        {
                            <img class="cd-hero-card__image" src="@Program.ImagenUrl" alt="@Program.Nombre" />
                        }
                        else
                        {
                            <img class="cd-hero-card__image" src="https://images.unsplash.com/photo-1548438294-1ad5d5f4f063?w=1200&q=80" alt="Placeholder" />
                        }
                        <div class="cd-hero-card__overlay"></div>
                        <div class="cd-hero-card__identity">
                            <img class="cd-hero-card__avatar" src="@(Program.CreadoPorNavigation?.ImagenPerfil ?? "/uploads/profiles/DefaultProfile.png")" alt="Avatar" />
                            <div class="cd-hero-card__id-text">
                                <h1 class="cd-hero-card__name">@Program.Nombre</h1>
                                <span class="cd-hero-card__location">
                                    <i class="fas fa-user-tie"></i> Creado por @(Program.CreadoPorNavigation?.Nombre) @(Program.CreadoPorNavigation?.Apellido)
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="cd-hero-card__body">
                        <div class="cd-tags">
                            <span class="cd-tag cd-tag--verified">
                                <i class="fas fa-check-circle"></i> PROGRAMA INSTITUCIONAL
                            </span>
                            <span class="cd-tag">@GetProgramTypeLabel(Program).ToUpper()</span>
                            <span class="cd-tag">@Program.IdCategoriaNavigation?.Nombre.ToUpper()</span>
                            <span class="cd-tag">@Program.Estado.ToUpper()</span>
                        </div>
                        <div class="cd-impact">
                            <h2 class="cd-impact__title">Resumen del Impacto</h2>
                            <p class="cd-impact__quote">
                                Este programa busca proporcionar apoyo directo para cubrir necesidades de @Program.IdCategoriaNavigation?.Nombre.
                            </p>
                        </div>
                    </div>
                </article>

                <section class="cd-story-card">
                    <h3 class="cd-story-card__title">
                        <i class="fas fa-book-open cd-story-card__title-icon"></i>
                        Descripción del Programa
                    </h3>
                    <div class="cd-story-card__body">
                        <p>@Program.Descripcion</p>
                    </div>
                </section>

                <section class="cd-metrics-card">
                    <div class="cd-vuln">
                        <span class="cd-vuln__label">ESTADO ACTUAL</span>
                        <div class="cd-vuln__ring-wrap">
                            <svg class="cd-vuln__svg" viewBox="0 0 100 100">
                                <circle cx="50" cy="50" r="45" fill="none" stroke="#e6e4dc" stroke-width="8" />
                                <circle cx="50" cy="50" r="45" fill="none" stroke="#22c55e" stroke-width="8"
                                        stroke-dasharray="@(progresoPrincipal * 2.82) 282" stroke-linecap="round" transform="rotate(-90 50 50)" />
                            </svg>
                            <div class="cd-vuln__center">
                                <span class="cd-vuln__score">@progresoPrincipal<span class="cd-vuln__denom">%</span></span>
                                <span class="cd-vuln__badge">@GetPrimaryProgressLabel(Program)</span>
                            </div>
                        </div>
                    </div>

                    <div class="cd-metric-analysis">
                        <span class="cd-metric-analysis__label">Análisis del Programa</span>

                        @if (ProgramAcceptsDonations(Program))
                        {
                            <div class="cd-metric-row">
                                <div class="cd-metric-row__header">
                                    <span class="cd-metric-row__name">Monto Recaudado</span>
                                    <span class="cd-metric-row__pct">@totalRecaudado.ToString("C", CultureInfo.GetCultureInfo("es-SV"))</span>
                                </div>
                                <div class="cd-metric-row__track">
                                    <div class="cd-metric-row__fill" style="width: @progresoFinanciero%"></div>
                                </div>
                            </div>
                            <div class="cd-metric-row">
                                <div class="cd-metric-row__header">
                                    <span class="cd-metric-row__name">Meta del Programa</span>
                                    <span class="cd-metric-row__pct">@Program.MetaFinanciera.ToString("C", CultureInfo.GetCultureInfo("es-SV"))</span>
                                </div>
                            </div>
                        }

                        @if (ProgramAcceptsVolunteers(Program))
                        {
                            <div class="cd-metric-row">
                                <div class="cd-metric-row__header">
                                    <span class="cd-metric-row__name">Voluntarios inscritos</span>
                                    <span class="cd-metric-row__pct">@totalVoluntarios</span>
                                </div>
                                <div class="cd-metric-row__track">
                                    <div class="cd-metric-row__fill" style="width: @progresoVoluntariado%"></div>
                                </div>
                            </div>
                            <div class="cd-metric-row">
                                <div class="cd-metric-row__header">
                                    <span class="cd-metric-row__name">Meta de voluntarios</span>
                                    <span class="cd-metric-row__pct">@Program.MetaVoluntarios</span>
                                </div>
                            </div>
                        }
                    </div>
                </section>
            </main>

            <aside class="cd-sidebar">
                @if (!string.IsNullOrWhiteSpace(FeedbackMessage))
                {
                    <div class="bulma-notification @(IsSuccess ? "bulma-is-success" : "bulma-is-danger") bulma-is-light">
                        @FeedbackMessage
                    </div>
                }

                <div class="cd-sidebar__funding">
                    @if (ProgramAcceptsDonations(Program))
                    {
                        <div class="cd-sidebar__funding-top">
                            <span class="cd-sidebar__amount">@totalRecaudado.ToString("C", CultureInfo.GetCultureInfo("es-SV"))</span>
                            <span class="cd-sidebar__goal">de @Program.MetaFinanciera.ToString("C", CultureInfo.GetCultureInfo("es-SV"))</span>
                        </div>
                    }
                    else
                    {
                        <div class="cd-sidebar__funding-top">
                            <span class="cd-sidebar__amount">@totalVoluntarios voluntarios</span>
                            <span class="cd-sidebar__goal">de @Program.MetaVoluntarios necesarios</span>
                        </div>
                    }

                    <div class="cd-sidebar__progress-track">
                        <div class="cd-sidebar__progress-fill" style="width: @progresoPrincipal%"></div>
                    </div>

                    <div class="cd-sidebar__funding-meta">
                        <span class="cd-sidebar__funded-pct">@progresoPrincipal% COMPLETADO</span>
                        <span class="cd-sidebar__days-left">@GetSidebarMetaText(Program, totalVoluntarios)</span>
                    </div>

                    @if (puedeDonar)
                    {
                        <button type="button"
                                class="bulma-button bulma-is-warning bulma-is-fullwidth cd-sidebar__btn-support"
                                @onclick="HandleDonateClick">
                            <i class="fas fa-heart"></i>
                            <strong>Contribuir al Programa</strong>
                        </button>
                    }

                    @if (puedeUnirse)
                    {
                        <button type="button"
                                class="bulma-button bulma-is-success bulma-is-fullwidth cd-sidebar__btn-support"
                                @onclick="HandleVolunteerSignupAsync"
                                disabled="@IsJoiningVolunteer">
                            <i class="fas fa-hands-helping"></i>
                            <strong>@(IsJoiningVolunteer ? "Registrando..." : "Unirme como voluntario")</strong>
                        </button>
                    }

                    @if (ProgramAcceptsVolunteers(Program) && UserIsAlreadyVolunteer)
                    {
                        <button type="button" class="bulma-button bulma-is-fullwidth cd-sidebar__btn-support cd-sidebar__btn-support--disabled" disabled>
                            <i class="fas fa-user-check"></i>
                            <strong>Ya eres voluntario de este programa</strong>
                        </button>
                    }

                    @if (!puedeDonar && !puedeUnirse && !UserIsAlreadyVolunteer)
                    {
                        <button type="button" class="bulma-button bulma-is-fullwidth cd-sidebar__btn-support cd-sidebar__btn-support--disabled" disabled>
                            <i class="fas fa-lock"></i>
                            <strong>@GetDisabledActionText(Program, totalVoluntarios)</strong>
                        </button>
                    }
                </div>

                <div class="cd-sidebar__trust">
                    @if (ProgramAcceptsDonations(Program))
                    {
                        <div class="cd-sidebar__trust-item">
                            <div class="cd-sidebar__trust-icon cd-sidebar__trust-icon--green">
                                <i class="fas fa-shield-heart"></i>
                            </div>
                            <div>
                                <h4 class="cd-sidebar__trust-title">Donación Institucional</h4>
                                <p class="cd-sidebar__trust-desc">Tu aporte apoya directamente las metas del programa.</p>
                            </div>
                        </div>
                    }

                    @if (ProgramAcceptsVolunteers(Program))
                    {
                        <div class="cd-sidebar__trust-item">
                            <div class="cd-sidebar__trust-icon cd-sidebar__trust-icon--yellow">
                                <i class="fas fa-people-group"></i>
                            </div>
                            <div>
                                <h4 class="cd-sidebar__trust-title">Voluntariado Comunitario</h4>
                                <p class="cd-sidebar__trust-desc">Tu tiempo y participación fortalecen el alcance del programa.</p>
                            </div>
                        </div>
                    }
                </div>
            </aside>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private Programa? Program { get; set; }
    private Usuario? CurrentUser { get; set; }
    private bool UserIsAlreadyVolunteer { get; set; }
    private bool IsJoiningVolunteer { get; set; }
    private bool IsSuccess { get; set; }
    private string? FeedbackMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadProgramAsync();

        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userIdStr = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (int.TryParse(userIdStr, out var userId))
        {
            CurrentUser = await UsuarioService.ObtenerPorId(userId);
            UpdateVolunteerState();
        }
    }

    private async Task LoadProgramAsync()
    {
        Program = await ProgramaService.ObtenerPorIdConDetallesAsync(Id);
    }

    private void UpdateVolunteerState()
    {
        UserIsAlreadyVolunteer = Program?.InscripcionesVoluntarios?.Any(i =>
            i.IdUsuario == CurrentUser?.Id &&
            string.Equals(i.Estado, "Activo", StringComparison.OrdinalIgnoreCase)) ?? false;
    }

    private static decimal GetTotalRecaudado(Programa program)
    {
        return program.Donaciones?.Where(d => d.Estado == "Completado").Sum(d => d.Monto) ?? 0m;
    }

    private static int GetTotalVoluntariosActivos(Programa program)
    {
        return program.InscripcionesVoluntarios?.Count(i =>
            string.Equals(i.Estado, "Activo", StringComparison.OrdinalIgnoreCase)) ?? 0;
    }

    private static int CalcularPorcentaje(decimal meta, decimal actual)
    {
        if (meta <= 0) return 0;
        return Math.Clamp((int)Math.Round((actual / meta) * 100), 0, 100);
    }

    private static int CalcularPorcentaje(int meta, int actual)
    {
        if (meta <= 0) return 0;
        return Math.Clamp((int)Math.Round((decimal)actual / meta * 100), 0, 100);
    }

    private static bool ProgramAcceptsDonations(Programa program)
    {
        return string.Equals(program.TipoPrograma, "Financiero", StringComparison.OrdinalIgnoreCase) ||
               string.Equals(program.TipoPrograma, "Hibrido", StringComparison.OrdinalIgnoreCase);
    }

    private static bool ProgramAcceptsVolunteers(Programa program)
    {
        return string.Equals(program.TipoPrograma, "Voluntariado", StringComparison.OrdinalIgnoreCase) ||
               string.Equals(program.TipoPrograma, "Hibrido", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsProgramActive(Programa program)
    {
        return !string.Equals(program.Estado, "Inactivo", StringComparison.OrdinalIgnoreCase);
    }

    private static bool VolunteerCapacityReached(Programa program, int totalVoluntarios)
    {
        return ProgramAcceptsVolunteers(program) &&
               program.MetaVoluntarios > 0 &&
               totalVoluntarios >= program.MetaVoluntarios;
    }

    private static int GetProgresoPrincipal(Programa program, int progresoFinanciero, int progresoVoluntariado)
    {
        return ProgramAcceptsDonations(program) ? progresoFinanciero : progresoVoluntariado;
    }

    private static string GetPrimaryProgressLabel(Programa program)
    {
        return ProgramAcceptsDonations(program) ? "RECAUDADO" : "VOLUNTARIOS";
    }

    private static string GetProgramTypeLabel(Programa program)
    {
        return program.TipoPrograma switch
        {
            "Voluntariado" => "Voluntariado",
            "Hibrido" => "Híbrido",
            _ => "Financiero"
        };
    }

    private static string GetSidebarMetaText(Programa program, int totalVoluntarios)
    {
        if (ProgramAcceptsDonations(program) && ProgramAcceptsVolunteers(program))
        {
            var totalDonantes = program.Donaciones?.Count(d => d.Estado == "Completado") ?? 0;
            return $"{totalDonantes} donantes y {totalVoluntarios} voluntarios";
        }

        if (ProgramAcceptsVolunteers(program))
        {
            return $"{totalVoluntarios} voluntarios inscritos";
        }

        var donantes = program.Donaciones?.Count(d => d.Estado == "Completado") ?? 0;
        return $"{donantes} donantes";
    }

    private static string GetDisabledActionText(Programa program, int totalVoluntarios)
    {
        if (!IsProgramActive(program))
        {
            return "Programa inactivo";
        }

        if (ProgramAcceptsVolunteers(program) && VolunteerCapacityReached(program, totalVoluntarios))
        {
            return "Meta de voluntarios alcanzada";
        }

        return "Sin acciones disponibles";
    }

    private void HandleDonateClick()
    {
        Navigation.NavigateTo($"/donate/program/{Id}");
    }

    private async Task HandleVolunteerSignupAsync()
    {
        FeedbackMessage = null;

        if (Program is null)
        {
            return;
        }

        if (CurrentUser is null)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        if (!ProgramAcceptsVolunteers(Program))
        {
            FeedbackMessage = "Este programa no acepta voluntariado.";
            IsSuccess = false;
            return;
        }

        if (UserIsAlreadyVolunteer)
        {
            FeedbackMessage = "Ya estás inscrito como voluntario en este programa.";
            IsSuccess = false;
            return;
        }

        if (VolunteerCapacityReached(Program, GetTotalVoluntariosActivos(Program)))
        {
            FeedbackMessage = "La meta de voluntarios ya fue alcanzada.";
            IsSuccess = false;
            return;
        }

        IsJoiningVolunteer = true;

        try
        {
            var exists = await DbContext.InscripcionesVoluntarios.AnyAsync(i =>
                i.IdPrograma == Program.Id &&
                i.IdUsuario == CurrentUser.Id &&
                i.Estado == "Activo");

            if (exists)
            {
                UserIsAlreadyVolunteer = true;
                FeedbackMessage = "Ya estás inscrito como voluntario en este programa.";
                IsSuccess = false;
                return;
            }

            DbContext.InscripcionesVoluntarios.Add(new InscripcionesVoluntario
            {
                IdPrograma = Program.Id,
                IdUsuario = CurrentUser.Id,
                FechaInscripcion = DateTime.Now,
                Estado = "Activo"
            });

            await DbContext.SaveChangesAsync();
            await LoadProgramAsync();
            UpdateVolunteerState();

            FeedbackMessage = "Te registraste como voluntario correctamente.";
            IsSuccess = true;
        }
        catch (Exception ex)
        {
            FeedbackMessage = "No se pudo registrar el voluntariado: " + ex.Message;
            IsSuccess = false;
        }
        finally
        {
            IsJoiningVolunteer = false;
        }
    }
}
