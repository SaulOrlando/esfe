@*
  ProgramDetail.razor
  Propósito: Mostrar detalles de un programa, incluyendo metas financieras y/o voluntariado.
*@
@page "/programs/{Id:int}"
@using Microsoft.EntityFrameworkCore
@using ProyectoSocioEconomico.Application.Interfaces
@using ProyectoSocioEconomico.Domain.Entities
@using ProyectoSocioEconomico.Infrastructure.Data
@using ProyectoSocioEconomico.WebUI.Services
@using System.ComponentModel.DataAnnotations
@using System.Globalization
@inject IProgramaService ProgramaService
@inject IUsuarioService UsuarioService
@inject ICasoService CasoService
@inject CustomAuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation
@inject AppDbContext DbContext

@if (IsLoading)
{
    <div class="bulma-container">
        <p>Cargando detalles del programa...</p>
    </div>
}
else if (Program == null)
{
    <div class="bulma-container">
        <div class="bulma-notification bulma-is-light">
            <p>Este programa no est&aacute; disponible para el p&uacute;blico.</p>
        </div>
        <a href="/programs" class="bulma-button bulma-is-warning">Volver a programas</a>
    </div>
}
else
{
    var totalRecaudado = GetTotalRecaudado(Program);
    var totalVoluntarios = GetTotalVoluntariosActivos(Program);
    var progresoFinanciero = CalcularPorcentaje(Program.MetaFinanciera, totalRecaudado);
    var progresoVoluntariado = CalcularPorcentaje(Program.MetaVoluntarios, totalVoluntarios);
    var progresoPrincipal = GetProgresoPrincipal(Program, progresoFinanciero, progresoVoluntariado);
    var puedeDonar = ProgramAcceptsDonations(Program) && IsProgramActive(Program);
    var puedeUnirse = ProgramAcceptsVolunteers(Program) &&
                      !CurrentUserIsAdmin &&
                      !CurrentUserIsBeneficiary &&
                      !CurrentUserHasCaseAsBeneficiary &&
                      IsProgramActive(Program) &&
                      !UserIsAlreadyVolunteer &&
                      !HasPendingVolunteerRequest &&
                      !UserBelongsToAnotherVolunteerProgram &&
                      !VolunteerCapacityReached(Program, totalVoluntarios);

    <div class="cd-page">
        <div class="cd-layout">
            <main class="cd-main">
                <article class="cd-hero-card">
                    <div class="cd-hero-card__image-wrap">
                        @if (!string.IsNullOrEmpty(Program.ImagenUrl))
                        {
                            <img class="cd-hero-card__image" src="@Program.ImagenUrl" alt="@Program.Nombre" />
                        }
                        else
                        {
                            <img class="cd-hero-card__image" src="https://images.unsplash.com/photo-1548438294-1ad5d5f4f063?w=1200&q=80" alt="Placeholder" />
                        }
                        <div class="cd-hero-card__overlay"></div>
                        <div class="cd-hero-card__identity">
                            <img class="cd-hero-card__avatar" src="@(Program.CreadoPorNavigation?.ImagenPerfil ?? "/uploads/profiles/DefaultProfile.png")" alt="Avatar" />
                            <div class="cd-hero-card__id-text">
                                <h1 class="cd-hero-card__name">@Program.Nombre</h1>
                                <span class="cd-hero-card__location">
                                    <i class="fas fa-user-tie"></i> Creado por @(Program.CreadoPorNavigation?.Nombre) @(Program.CreadoPorNavigation?.Apellido)
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="cd-hero-card__body">
                        <div class="cd-tags">
                            <span class="cd-tag cd-tag--verified">
                                <i class="fas fa-check-circle"></i> PROGRAMA INSTITUCIONAL
                            </span>
                            <span class="cd-tag">@GetProgramTypeLabel(Program).ToUpper()</span>
                            <span class="cd-tag">@Program.IdCategoriaNavigation?.Nombre.ToUpper()</span>
                            <span class="cd-tag">@Program.Estado.ToUpper()</span>
                        </div>
                        <div class="cd-impact">
                            <h2 class="cd-impact__title">Resumen del Impacto</h2>
                            <p class="cd-impact__quote">
                                Este programa busca proporcionar apoyo directo para cubrir necesidades de @Program.IdCategoriaNavigation?.Nombre.
                            </p>
                        </div>
                    </div>
                </article>

                <section class="cd-story-card">
                    <h3 class="cd-story-card__title">
                        <i class="fas fa-book-open cd-story-card__title-icon"></i>
                        Descripción del Programa
                    </h3>
                    <div class="cd-story-card__body">
                        <p>@Program.Descripcion</p>
                    </div>
                </section>

                @if (ProgramAcceptsVolunteers(Program) && ProgramVolunteerDays.Any())
                {
                    <section class="cd-story-card">
                        <h3 class="cd-story-card__title">
                            <i class="fas fa-calendar-days cd-story-card__title-icon"></i>
                            Jornadas de voluntariado
                        </h3>
                        <div class="cd-story-card__body">
                            <p>El programa recibirá apoyo voluntario en los siguientes días:</p>
                            <div class="cd-tags">
                                @foreach (var day in ProgramVolunteerDays)
                                {
                                    <span class="cd-tag">@day</span>
                                }
                            </div>
                        </div>
                    </section>
                }

                <section class="cd-metrics-card">
                    <div class="cd-vuln">
                        <span class="cd-vuln__label">ESTADO ACTUAL</span>
                        <div class="cd-vuln__ring-wrap">
                            <svg class="cd-vuln__svg" viewBox="0 0 100 100">
                                <circle cx="50" cy="50" r="45" fill="none" stroke="#e6e4dc" stroke-width="8" />
                                <circle cx="50" cy="50" r="45" fill="none" stroke="#22c55e" stroke-width="8"
                                        stroke-dasharray="@(progresoPrincipal * 2.82) 282" stroke-linecap="round" transform="rotate(-90 50 50)" />
                            </svg>
                            <div class="cd-vuln__center">
                                <span class="cd-vuln__score">@progresoPrincipal<span class="cd-vuln__denom">%</span></span>
                                <span class="cd-vuln__badge">@GetPrimaryProgressLabel(Program)</span>
                            </div>
                        </div>
                    </div>

                    <div class="cd-metric-analysis">
                        <span class="cd-metric-analysis__label">Análisis del Programa</span>

                        @if (ProgramAcceptsDonations(Program))
                        {
                            <div class="cd-metric-row">
                                <div class="cd-metric-row__header">
                                    <span class="cd-metric-row__name">Monto Recaudado</span>
                                    <span class="cd-metric-row__pct">@totalRecaudado.ToString("C", CultureInfo.GetCultureInfo("es-SV"))</span>
                                </div>
                                <div class="cd-metric-row__track">
                                    <div class="cd-metric-row__fill" style="width: @progresoFinanciero%"></div>
                                </div>
                            </div>
                            <div class="cd-metric-row">
                                <div class="cd-metric-row__header">
                                    <span class="cd-metric-row__name">Meta del Programa</span>
                                    <span class="cd-metric-row__pct">@Program.MetaFinanciera.ToString("C", CultureInfo.GetCultureInfo("es-SV"))</span>
                                </div>
                            </div>
                        }

                        @if (ProgramAcceptsVolunteers(Program))
                        {
                            <div class="cd-metric-row">
                                <div class="cd-metric-row__header">
                                    <span class="cd-metric-row__name">Voluntarios inscritos</span>
                                    <span class="cd-metric-row__pct">@totalVoluntarios</span>
                                </div>
                                <div class="cd-metric-row__track">
                                    <div class="cd-metric-row__fill" style="width: @progresoVoluntariado%"></div>
                                </div>
                            </div>
                            <div class="cd-metric-row">
                                <div class="cd-metric-row__header">
                                    <span class="cd-metric-row__name">Meta de voluntarios</span>
                                    <span class="cd-metric-row__pct">@Program.MetaVoluntarios</span>
                                </div>
                            </div>
                        }
                    </div>
                </section>
            </main>

            <aside class="cd-sidebar">
                @if (!string.IsNullOrWhiteSpace(FeedbackMessage))
                {
                    <div class="bulma-notification @(IsSuccess ? "bulma-is-success" : "bulma-is-danger") bulma-is-light">
                        @FeedbackMessage
                    </div>
                }

                <div class="cd-sidebar__funding">
                    @if (ProgramAcceptsDonations(Program))
                    {
                        <div class="cd-sidebar__funding-top">
                            <span class="cd-sidebar__amount">@totalRecaudado.ToString("C", CultureInfo.GetCultureInfo("es-SV"))</span>
                            <span class="cd-sidebar__goal">de @Program.MetaFinanciera.ToString("C", CultureInfo.GetCultureInfo("es-SV"))</span>
                        </div>
                    }
                    else
                    {
                        <div class="cd-sidebar__funding-top">
                            <span class="cd-sidebar__amount">@totalVoluntarios voluntarios</span>
                            <span class="cd-sidebar__goal">de @Program.MetaVoluntarios necesarios</span>
                        </div>
                    }

                    <div class="cd-sidebar__progress-track">
                        <div class="cd-sidebar__progress-fill" style="width: @progresoPrincipal%"></div>
                    </div>

                    <div class="cd-sidebar__funding-meta">
                        <span class="cd-sidebar__funded-pct">@progresoPrincipal% COMPLETADO</span>
                        <span class="cd-sidebar__days-left">@GetSidebarMetaText(Program, totalVoluntarios)</span>
                    </div>

                    <div class="cd-sidebar__actions">
                        @if (puedeDonar)
                        {
                            <button type="button"
                                    class="bulma-button bulma-is-warning bulma-is-fullwidth cd-sidebar__btn-support"
                                    @onclick="HandleDonateClick">
                                <i class="fas fa-heart"></i>
                                <strong>Contribuir al Programa</strong>
                            </button>
                        }

                        @if (puedeUnirse)
                        {
                            <button type="button"
                                    class="bulma-button bulma-is-success bulma-is-fullwidth cd-sidebar__btn-support"
                                    @onclick="OpenVolunteerModal"
                                    disabled="@IsJoiningVolunteer">
                                <i class="fas fa-hands-helping"></i>
                                <strong>@(IsJoiningVolunteer ? "Registrando..." : "Unirme como voluntario")</strong>
                            </button>
                        }

                        @if (ProgramAcceptsVolunteers(Program) && UserIsAlreadyVolunteer)
                        {
                            <button type="button" class="bulma-button bulma-is-fullwidth cd-sidebar__btn-support cd-sidebar__btn-support--disabled" disabled>
                                <i class="fas fa-user-check"></i>
                                <strong>Ya eres voluntario de este programa</strong>
                            </button>
                        }

                        @if (ProgramAcceptsVolunteers(Program) && HasPendingVolunteerRequest)
                        {
                            <button type="button" class="bulma-button bulma-is-fullwidth cd-sidebar__btn-support cd-sidebar__btn-support--disabled" disabled>
                                <i class="fas fa-hourglass-half"></i>
                                <strong>Tienes una solicitud pendiente</strong>
                            </button>
                        }

                        @if (ProgramAcceptsVolunteers(Program) && UserBelongsToAnotherVolunteerProgram)
                        {
                            <button type="button" class="bulma-button bulma-is-fullwidth cd-sidebar__btn-support cd-sidebar__btn-support--disabled" disabled>
                                <i class="fas fa-user-lock"></i>
                                <strong>Ya participas en otro programa</strong>
                            </button>
                        }

                        @if (ProgramAcceptsVolunteers(Program) && (CurrentUserIsBeneficiary || CurrentUserHasCaseAsBeneficiary))
                        {
                            <button type="button" class="bulma-button bulma-is-fullwidth cd-sidebar__btn-support cd-sidebar__btn-support--disabled" disabled>
                                <i class="fas fa-hand-holding-heart"></i>
                                <strong>Los beneficiarios no pueden postularse</strong>
                            </button>
                        }

                        @if (!puedeDonar && !puedeUnirse && !UserIsAlreadyVolunteer && !HasPendingVolunteerRequest && !UserBelongsToAnotherVolunteerProgram && !CurrentUserIsBeneficiary && !CurrentUserHasCaseAsBeneficiary)
                        {
                            <button type="button" class="bulma-button bulma-is-fullwidth cd-sidebar__btn-support cd-sidebar__btn-support--disabled" disabled>
                                <i class="fas fa-lock"></i>
                                <strong>@GetDisabledActionText(Program, totalVoluntarios)</strong>
                            </button>
                        }
                    </div>
                </div>

                <div class="cd-sidebar__trust">
                    @if (ProgramAcceptsDonations(Program))
                    {
                        <div class="cd-sidebar__trust-item">
                            <div class="cd-sidebar__trust-icon cd-sidebar__trust-icon--green">
                                <i class="fas fa-shield-heart"></i>
                            </div>
                            <div>
                                <h4 class="cd-sidebar__trust-title">Donación Institucional</h4>
                                <p class="cd-sidebar__trust-desc">Tu aporte apoya directamente las metas del programa.</p>
                            </div>
                        </div>
                    }

                    @if (ProgramAcceptsVolunteers(Program))
                    {
                        <div class="cd-sidebar__trust-item">
                            <div class="cd-sidebar__trust-icon cd-sidebar__trust-icon--yellow">
                                <i class="fas fa-people-group"></i>
                            </div>
                            <div>
                                <h4 class="cd-sidebar__trust-title">Voluntariado Comunitario</h4>
                                <p class="cd-sidebar__trust-desc">Tu tiempo y participación fortalecen el alcance del programa.</p>
                            </div>
                        </div>
                    }
                </div>
            </aside>
            @if (IsVolunteerModalOpen)
            {
                <div class="bulma-modal bulma-is-active cd-volunteer-modal" role="dialog" aria-modal="true" aria-labelledby="volunteer-modal-title">
                    <div class="bulma-modal-background" @onclick="CloseVolunteerModal"></div>
                    <div class="bulma-modal-card cd-volunteer-modal__card">
                        <header class="bulma-modal-card-head cd-volunteer-modal__head">
                            <div>
                                <p id="volunteer-modal-title" class="bulma-modal-card-title cd-volunteer-modal__title">Formulario de voluntariado</p>
                                <p class="cd-volunteer-modal__subtitle">Selecciona los días en los que tienes disponibilidad para apoyar este programa.</p>
                            </div>
                            <button type="button" class="bulma-delete" aria-label="Cerrar" @onclick="CloseVolunteerModal"></button>
                        </header>

                        <EditForm Model="VolunteerForm" OnValidSubmit="HandleVolunteerSignupAsync" FormName="VolunteerSignupForm">
                            <DataAnnotationsValidator />

                            <section class="bulma-modal-card-body cd-volunteer-modal__body">
                                @if (!string.IsNullOrWhiteSpace(VolunteerFormFeedback))
                                {
                                    <div class="bulma-notification @(IsSuccess ? "bulma-is-success" : "bulma-is-danger") bulma-is-light">
                                        @VolunteerFormFeedback
                                    </div>
                                }

                                <div class="bulma-field">
                                    <label class="bulma-label" for="volunteer-days">Días disponibles</label>
                                    @if (ProgramVolunteerDays.Any())
                                    {
                                        <div class="cd-volunteer-modal__days">
                                            @foreach (var day in ProgramVolunteerDays)
                                            {
                                                <label class="cd-volunteer-modal__day-option">
                                                    <input type="checkbox"
                                                           checked="@VolunteerForm.DiasSeleccionados.Contains(day)"
                                                           @onchange="args => ToggleVolunteerDay(day, args.Value is bool selected && selected)" />
                                                    <span>@day</span>
                                                </label>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <p class="bulma-help">Este programa todavía no tiene días configurados para voluntariado.</p>
                                    }
                                    <ValidationMessage For="@(() => VolunteerForm.DiasSeleccionados)" class="bulma-help bulma-is-danger" />
                                </div>
                            </section>

                            <footer class="bulma-modal-card-foot cd-volunteer-modal__footer">
                                <button type="button" class="bulma-button" @onclick="CloseVolunteerModal" disabled="@IsJoiningVolunteer">Cancelar</button>
                                <button type="submit" class="bulma-button bulma-is-success" disabled="@IsJoiningVolunteer">
                                    @(IsJoiningVolunteer ? "Registrando..." : "Confirmar voluntariado")
                                </button>
                            </footer>
                        </EditForm>
                    </div>
                </div>
            }

            @if (IsAdminVolunteerBlockedModalOpen)
            {
                <div class="bulma-modal bulma-is-active cd-volunteer-modal" role="dialog" aria-modal="true" aria-labelledby="admin-volunteer-blocked-title">
                    <div class="bulma-modal-background" @onclick="CloseAdminVolunteerBlockedModal"></div>
                    <div class="bulma-modal-card cd-volunteer-modal__card">
                        <header class="bulma-modal-card-head cd-volunteer-modal__head">
                            <div>
                                <p id="admin-volunteer-blocked-title" class="bulma-modal-card-title cd-volunteer-modal__title">Acción no permitida</p>
                                <p class="cd-volunteer-modal__subtitle">Las cuentas administradoras no pueden postularse como voluntarias.</p>
                            </div>
                            <button type="button" class="bulma-delete" aria-label="Cerrar" @onclick="CloseAdminVolunteerBlockedModal"></button>
                        </header>

                        <section class="bulma-modal-card-body cd-volunteer-modal__body">
                            <p>Tu usuario tiene rol de administrador, por lo que no puedes unirte a programas desde este flujo.</p>
                        </section>

                        <footer class="bulma-modal-card-foot cd-volunteer-modal__footer">
                            <button type="button" class="bulma-button bulma-is-warning" @onclick="CloseAdminVolunteerBlockedModal">Entendido</button>
                        </footer>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private Programa? Program { get; set; }
    private bool IsLoading { get; set; } = true;
    private Usuario? CurrentUser { get; set; }
    private VolunteerSignupFormModel VolunteerForm { get; set; } = new();
    private List<string> ProgramVolunteerDays { get; set; } = new();
    private bool IsVolunteerModalOpen { get; set; }
    private bool UserIsAlreadyVolunteer { get; set; }
    private bool HasPendingVolunteerRequest { get; set; }
    private bool UserBelongsToAnotherVolunteerProgram { get; set; }
    private bool CurrentUserIsAdmin { get; set; }
    private bool CurrentUserIsBeneficiary { get; set; }
    private bool CurrentUserHasCaseAsBeneficiary { get; set; }
    private bool IsJoiningVolunteer { get; set; }
    private bool IsSuccess { get; set; }
    private bool IsAdminVolunteerBlockedModalOpen { get; set; }
    private string? FeedbackMessage { get; set; }
    private string? VolunteerFormFeedback { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadProgramAsync();

        if (Program is null)
        {
            IsLoading = false;
            return;
        }

        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userIdStr = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (int.TryParse(userIdStr, out var userId))
        {
            CurrentUser = await UsuarioService.ObtenerPorId(userId);
            CurrentUserIsAdmin = IsAdmin(CurrentUser);
            CurrentUserIsBeneficiary = IsBeneficiary(CurrentUser);
            CurrentUserHasCaseAsBeneficiary = await CasoService.UsuarioYaTieneCasoAsync(userId);
            await RefreshVolunteerStateAsync();
        }

        IsLoading = false;
    }

    private async Task LoadProgramAsync()
    {
        Program = await ProgramaService.ObtenerPublicoPorIdConDetallesAsync(Id);
        ProgramVolunteerDays = ParseDays(Program?.DiasVoluntariado);
    }

    private async Task RefreshVolunteerStateAsync()
    {
        UserIsAlreadyVolunteer = false;
        HasPendingVolunteerRequest = false;
        UserBelongsToAnotherVolunteerProgram = false;

        if (CurrentUser is null)
        {
            return;
        }

        var activeRequest = await DbContext.InscripcionesVoluntarios
            .AsNoTracking()
            .Include(i => i.IdProgramaNavigation)
            .Where(i =>
                i.IdUsuario == CurrentUser.Id &&
                (i.Estado == "Pendiente" || i.Estado == "Aprobado" || i.Estado == "Activo"))
            .OrderByDescending(i => i.FechaInscripcion)
            .FirstOrDefaultAsync();

        if (activeRequest is null)
        {
            return;
        }

        if (string.Equals(activeRequest.Estado, "Pendiente", StringComparison.OrdinalIgnoreCase))
        {
            HasPendingVolunteerRequest = true;
            return;
        }

        if (activeRequest.IdPrograma == Id)
        {
            UserIsAlreadyVolunteer = true;
            return;
        }

        UserBelongsToAnotherVolunteerProgram = true;
    }

    private static decimal GetTotalRecaudado(Programa program)
    {
        return program.Donaciones?.Where(d => d.Estado == "Completado").Sum(d => d.Monto) ?? 0m;
    }

    private static int GetTotalVoluntariosActivos(Programa program)
    {
        return program.InscripcionesVoluntarios?.Count(i =>
            string.Equals(i.Estado, "Aprobado", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(i.Estado, "Activo", StringComparison.OrdinalIgnoreCase)) ?? 0;
    }

    private static int CalcularPorcentaje(decimal meta, decimal actual)
    {
        if (meta <= 0) return 0;
        return Math.Clamp((int)Math.Round((actual / meta) * 100), 0, 100);
    }

    private static int CalcularPorcentaje(int meta, int actual)
    {
        if (meta <= 0) return 0;
        return Math.Clamp((int)Math.Round((decimal)actual / meta * 100), 0, 100);
    }

    private static bool ProgramAcceptsDonations(Programa program)
    {
        return string.Equals(program.TipoPrograma, "Financiero", StringComparison.OrdinalIgnoreCase) ||
               string.Equals(program.TipoPrograma, "Hibrido", StringComparison.OrdinalIgnoreCase);
    }

    private static bool ProgramAcceptsVolunteers(Programa program)
    {
        return string.Equals(program.TipoPrograma, "Voluntariado", StringComparison.OrdinalIgnoreCase) ||
               string.Equals(program.TipoPrograma, "Hibrido", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsProgramActive(Programa program)
    {
        return !string.Equals(program.Estado, "Inactivo", StringComparison.OrdinalIgnoreCase);
    }

    private static bool VolunteerCapacityReached(Programa program, int totalVoluntarios)
    {
        return ProgramAcceptsVolunteers(program) &&
               program.MetaVoluntarios > 0 &&
               totalVoluntarios >= program.MetaVoluntarios;
    }

    private static int GetProgresoPrincipal(Programa program, int progresoFinanciero, int progresoVoluntariado)
    {
        return ProgramAcceptsDonations(program) ? progresoFinanciero : progresoVoluntariado;
    }

    private static string GetPrimaryProgressLabel(Programa program)
    {
        return ProgramAcceptsDonations(program) ? "RECAUDADO" : "VOLUNTARIOS";
    }

    private static string GetProgramTypeLabel(Programa program)
    {
        return program.TipoPrograma switch
        {
            "Voluntariado" => "Voluntariado",
            "Hibrido" => "Híbrido",
            _ => "Financiero"
        };
    }

    private static string GetSidebarMetaText(Programa program, int totalVoluntarios)
    {
        if (ProgramAcceptsDonations(program) && ProgramAcceptsVolunteers(program))
        {
            var totalDonantes = program.Donaciones?.Count(d => d.Estado == "Completado") ?? 0;
            return $"{totalDonantes} donantes y {totalVoluntarios} voluntarios";
        }

        if (ProgramAcceptsVolunteers(program))
        {
            return $"{totalVoluntarios} voluntarios inscritos";
        }

        var donantes = program.Donaciones?.Count(d => d.Estado == "Completado") ?? 0;
        return $"{donantes} donantes";
    }

    private string GetDisabledActionText(Programa program, int totalVoluntarios)
    {
        if (CurrentUserIsAdmin)
        {
            return "Los administradores no pueden postularse";
        }

        if (CurrentUserIsBeneficiary || CurrentUserHasCaseAsBeneficiary)
        {
            return "Los beneficiarios no pueden postularse";
        }

        if (!IsProgramActive(program))
        {
            return "Programa inactivo";
        }

        if (ProgramAcceptsVolunteers(program) && VolunteerCapacityReached(program, totalVoluntarios))
        {
            return "Meta de voluntarios alcanzada";
        }

        return "Sin acciones disponibles";
    }

    private void HandleDonateClick()
    {
        Navigation.NavigateTo($"/donate/program/{Id}");
    }

    private void OpenVolunteerModal()
    {
        FeedbackMessage = null;
        VolunteerFormFeedback = null;

        if (CurrentUserIsAdmin)
        {
            IsAdminVolunteerBlockedModalOpen = true;
            return;
        }

        if (CurrentUser is null)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        if (CurrentUserIsBeneficiary || CurrentUserHasCaseAsBeneficiary)
        {
            FeedbackMessage = "No puedes postularte como voluntario porque ya tienes un caso creado como beneficiario.";
            IsSuccess = false;
            return;
        }

        if (!ProgramVolunteerDays.Any())
        {
            FeedbackMessage = "Este programa no tiene días de voluntariado configurados todavía.";
            IsSuccess = false;
            return;
        }

        VolunteerForm = new VolunteerSignupFormModel();

        IsVolunteerModalOpen = true;
    }

    private void CloseVolunteerModal()
    {
        if (IsJoiningVolunteer)
        {
            return;
        }

        VolunteerFormFeedback = null;
        IsVolunteerModalOpen = false;
    }

    private void CloseAdminVolunteerBlockedModal()
    {
        IsAdminVolunteerBlockedModalOpen = false;
    }

    private async Task HandleVolunteerSignupAsync()
    {
        FeedbackMessage = null;
        VolunteerFormFeedback = null;

        if (Program is null)
        {
            return;
        }

        if (CurrentUser is null)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        if (!ProgramAcceptsVolunteers(Program))
        {
            FeedbackMessage = "Este programa no acepta voluntariado.";
            IsSuccess = false;
            return;
        }

        if (CurrentUserIsBeneficiary || CurrentUserHasCaseAsBeneficiary)
        {
            FeedbackMessage = "No puedes postularte como voluntario porque ya tienes un caso creado como beneficiario.";
            IsSuccess = false;
            return;
        }

        if (UserIsAlreadyVolunteer)
        {
            FeedbackMessage = "Ya estás inscrito como voluntario en este programa.";
            IsSuccess = false;
            return;
        }

        if (HasPendingVolunteerRequest)
        {
            FeedbackMessage = "Ya tienes una solicitud de voluntariado pendiente de revisión.";
            IsSuccess = false;
            return;
        }

        if (UserBelongsToAnotherVolunteerProgram)
        {
            FeedbackMessage = "Ya fuiste aprobado en otro programa y no puedes postularte a uno nuevo.";
            IsSuccess = false;
            return;
        }

        if (VolunteerCapacityReached(Program, GetTotalVoluntariosActivos(Program)))
        {
            FeedbackMessage = "La meta de voluntarios ya fue alcanzada.";
            IsSuccess = false;
            return;
        }

        IsJoiningVolunteer = true;

        try
        {
            var exists = await DbContext.InscripcionesVoluntarios.AnyAsync(i =>
                i.IdUsuario == CurrentUser.Id &&
                (i.Estado == "Pendiente" || i.Estado == "Aprobado" || i.Estado == "Activo"));

            if (exists)
            {
                await RefreshVolunteerStateAsync();
                VolunteerFormFeedback = "Ya tienes una postulación activa o una aprobación vigente en voluntariado.";
                FeedbackMessage = VolunteerFormFeedback;
                IsSuccess = false;
                return;
            }

            DbContext.InscripcionesVoluntarios.Add(new InscripcionesVoluntario
            {
                IdPrograma = Program.Id,
                IdUsuario = CurrentUser.Id,
                FechaInscripcion = DateTime.Now,
                CategoriaVoluntariado = Program.IdCategoriaNavigation?.Nombre ?? "General",
                DiasDisponibles = string.Join(", ", VolunteerForm.DiasSeleccionados),
                Estado = "Pendiente"
            });

            await DbContext.SaveChangesAsync();
            await LoadProgramAsync();
            await RefreshVolunteerStateAsync();

            FeedbackMessage = "Tu solicitud fue enviada y queda pendiente de aprobación administrativa.";
            VolunteerFormFeedback = FeedbackMessage;
            IsSuccess = true;
            IsVolunteerModalOpen = false;
        }
        catch (Exception ex)
        {
            VolunteerFormFeedback = "No se pudo registrar el voluntariado: " + ex.Message;
            FeedbackMessage = VolunteerFormFeedback;
            IsSuccess = false;
        }
        finally
        {
            IsJoiningVolunteer = false;
        }
    }

    private void ToggleVolunteerDay(string day, bool isSelected)
    {
        if (isSelected)
        {
            if (!VolunteerForm.DiasSeleccionados.Contains(day))
            {
                VolunteerForm.DiasSeleccionados.Add(day);
            }

            return;
        }

        VolunteerForm.DiasSeleccionados.Remove(day);
    }

    private static List<string> ParseDays(string? rawDays)
    {
        return string.IsNullOrWhiteSpace(rawDays)
            ? new List<string>()
            : rawDays
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();
    }

    private static bool IsAdmin(Usuario? usuario)
    {
        var roleName = usuario?.IdRolNavigation?.Nombre;
        return !string.IsNullOrWhiteSpace(roleName) &&
               roleName.Equals("Administrador", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsBeneficiary(Usuario? usuario)
    {
        var roleName = usuario?.IdRolNavigation?.Nombre;
        return !string.IsNullOrWhiteSpace(roleName) &&
               roleName.Equals("Beneficiario", StringComparison.OrdinalIgnoreCase);
    }

    private sealed class VolunteerSignupFormModel : IValidatableObject
    {
        public List<string> DiasSeleccionados { get; set; } = new();

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            if (DiasSeleccionados.Count == 0)
            {
                yield return new ValidationResult(
                    "Seleccione al menos un día disponible.",
                    new[] { nameof(DiasSeleccionados) });
            }
        }
    }
}
