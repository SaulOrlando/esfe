@*
  EditProgram.razor
  Propósito: Página para editar detalles de un programa (administración).
*@
@page "/program/{Id:int}/edit"
@page "/admin/programs/{Id:int}/edit"
@layout ProfileLayout
@rendermode InteractiveServer
@using ProyectoSocioEconomico.Application.Interfaces
@using ProyectoSocioEconomico.Domain.Entities
@using ProyectoSocioEconomico.WebUI.Services
@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@inject IProgramaService ProgramaService
@inject ICasoService CasoService
@inject IUsuarioService UsuarioService
@inject CustomAuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation

<div class="ep-page">
    @if (IsLoading)
    {
        <div class="ep-page-header">
            <div class="ep-page-header__left">
                <h1 class="ep-page-header__title">Cargando programa...</h1>
                <p class="ep-page-header__subtitle">Estamos preparando la información para edición.</p>
            </div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(ErrorMessage) && FormModel is null)
    {
        <section class="ep-card ep-card--message">
            <h1 class="ep-page-header__title">No se pudo cargar el programa</h1>
            <p class="ep-page-header__subtitle">@ErrorMessage</p>
            <a href="/admin/programs" class="ep-btn-back">Volver a programas</a>
        </section>
    }
    else if (FormModel is not null)
    {
        <div class="ep-page-header">
            <div class="ep-page-header__left">
                <h1 class="ep-page-header__title">Editar programa</h1>
                <p class="ep-page-header__subtitle">Actualice la información principal del programa y guarde los cambios.</p>
            </div>
            <div class="ep-status-badge">
                <span class="ep-status-badge__icon"><i class="fas fa-folder-open"></i></span>
                <span class="ep-status-badge__label">ESTADO:</span>
                <span class="ep-status-badge__value">@CurrentProgram?.Estado</span>
            </div>
        </div>

        <EditForm Model="FormModel" OnValidSubmit="HandleUpdateAsync" FormName="EditProgramForm">
            <DataAnnotationsValidator />

            <div class="ep-body">
                <div class="ep-main">
                    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
                    {
                        <div class="bulma-notification bulma-is-danger bulma-is-light">@ErrorMessage</div>
                    }

                    <section class="ep-card">
                        <h2 class="ep-card__title">
                            <span class="ep-card__title-icon ep-card__title-icon--yellow">
                                <i class="fas fa-pen-to-square"></i>
                            </span>
                            Información general
                        </h2>

                        <div class="ep-form-grid ep-form-grid--2col">
                            <div class="bulma-field ep-field">
                                <label class="bulma-label ep-label" for="program-title">Nombre del programa</label>
                                <div class="bulma-control ep-control">
                                    <InputText id="program-title" class="bulma-input ep-input" @bind-Value="FormModel.ProgramTitle" />
                                </div>
                                <ValidationMessage For="@(() => FormModel.ProgramTitle)" class="bulma-help bulma-is-danger" />
                            </div>

                            <div class="bulma-field ep-field">
                                <label class="bulma-label ep-label" for="category">Categoría</label>
                                <div class="bulma-control ep-control">
                                    <div class="bulma-select bulma-is-fullwidth ep-select-wrap">
                                        <InputSelect id="category" class="ep-select" @bind-Value="FormModel.CategoryId">
                                            <option value="">Seleccione una categoría</option>
                                            @foreach (var category in Categories)
                                            {
                                                <option value="@category.Id">@category.Nombre</option>
                                            }
                                        </InputSelect>
                                    </div>
                                </div>
                                <ValidationMessage For="@(() => FormModel.CategoryId)" class="bulma-help bulma-is-danger" />
                            </div>
                        </div>

                        <div class="bulma-field ep-field ep-field--narrow">
                            <label class="bulma-label ep-label" for="program-type">Tipo de programa</label>
                            <div class="bulma-control ep-control">
                                <div class="bulma-select bulma-is-fullwidth ep-select-wrap">
                                    <InputSelect id="program-type" class="ep-select" @bind-Value="FormModel.ProgramType">
                                        <option value="Financiero">Financiero</option>
                                        <option value="Voluntariado">Voluntariado</option>
                                        <option value="Hibrido">Híbrido</option>
                                    </InputSelect>
                                </div>
                            </div>
                            <ValidationMessage For="@(() => FormModel.ProgramType)" class="bulma-help bulma-is-danger" />
                        </div>

                        <div class="bulma-field ep-field ep-field--narrow">
                            <label class="bulma-label ep-label" for="program-status">Estado del programa</label>
                            <div class="bulma-control ep-control">
                                <div class="bulma-select bulma-is-fullwidth ep-select-wrap">
                                    <InputSelect id="program-status" class="ep-select" @bind-Value="FormModel.Status">
                                        <option value="Activo">Activo</option>
                                        <option value="Inactivo">Inactivo</option>
                                    </InputSelect>
                                </div>
                            </div>
                            <ValidationMessage For="@(() => FormModel.Status)" class="bulma-help bulma-is-danger" />
                            <p class="ep-field-note">El administrador puede activar o inactivar manualmente cualquier programa.</p>
                        </div>

                        <div class="bulma-field ep-field ep-field--full">
                            <label class="bulma-label ep-label" for="description">Descripción detallada</label>
                            <div class="bulma-control ep-control">
                                <InputTextArea id="description"
                                               class="bulma-textarea ep-textarea"
                                               rows="7"
                                               @bind-Value="FormModel.Description" />
                            </div>
                            <ValidationMessage For="@(() => FormModel.Description)" class="bulma-help bulma-is-danger" />
                            <p class="ep-char-count">Palabras: @WordCount/@MaxWords</p>
                        </div>
                    </section>

                    <section class="ep-card">
                        <h2 class="ep-card__title">
                            <span class="ep-card__title-icon ep-card__title-icon--yellow">
                                <i class="fas fa-hand-holding-dollar"></i>
                            </span>
                            Metas del programa
                        </h2>

                        @if (SupportsFinancialGoal(FormModel.ProgramType))
                        {
                        <div class="bulma-field ep-field ep-field--narrow">
                            <label class="bulma-label ep-label" for="amount">Monto meta</label>
                            <div class="bulma-control ep-control">
                                <div class="ep-money-wrap">
                                    <span class="ep-money-prefix">$</span>
                                    <InputNumber id="amount"
                                                 class="bulma-input ep-input ep-input--money"
                                                 @bind-Value="FormModel.RequiredAmount" />
                                </div>
                            </div>
                            <ValidationMessage For="@(() => FormModel.RequiredAmount)" class="bulma-help bulma-is-danger" />
                            <p class="ep-field-note">La meta financiera sí puede actualizarse para el programa.</p>
                        </div>
                        }

                        @if (SupportsVolunteerGoal(FormModel.ProgramType))
                        {
                        <div class="bulma-field ep-field ep-field--narrow">
                            <label class="bulma-label ep-label" for="volunteers-goal">Meta de voluntarios</label>
                            <div class="bulma-control ep-control">
                                <InputNumber id="volunteers-goal"
                                             class="bulma-input ep-input"
                                             min="1"
                                             step="1"
                                             @bind-Value="FormModel.VolunteerGoal" />
                            </div>
                            <ValidationMessage For="@(() => FormModel.VolunteerGoal)" class="bulma-help bulma-is-danger" />
                            <p class="ep-field-note">Define cuántos voluntarios necesita este programa.</p>
                        </div>

                        <div class="bulma-field ep-field ep-field--full">
                            <label class="bulma-label ep-label">Días de voluntariado</label>
                            <div class="ep-days-grid">
                                @foreach (var day in VolunteerDayOptions)
                                {
                                    <label class="ep-day-option">
                                        <input type="checkbox"
                                               checked="@FormModel.VolunteerDays.Contains(day)"
                                               @onchange="args => ToggleVolunteerDay(day, args.Value is bool selected && selected)" />
                                        <span>@day</span>
                                    </label>
                                }
                            </div>
                            <ValidationMessage For="@(() => FormModel.VolunteerDays)" class="bulma-help bulma-is-danger" />
                            <p class="ep-field-note">Estos días se mostrarán en el formulario de postulación del usuario.</p>
                        </div>
                        }
                    </section>

                    @if (SupportsVolunteerGoal(FormModel.ProgramType))
                    {
                        <section class="ep-card">
                            <h2 class="ep-card__title">
                                <span class="ep-card__title-icon ep-card__title-icon--yellow">
                                    <i class="fas fa-user-check"></i>
                                </span>
                                Solicitudes de voluntariado
                            </h2>

                            @if (!string.IsNullOrWhiteSpace(VolunteerReviewMessage))
                            {
                                <div class="bulma-notification @(VolunteerReviewSuccess ? "bulma-is-success" : "bulma-is-danger") bulma-is-light">
                                    @VolunteerReviewMessage
                                </div>
                            }

                            @if (VolunteerApplications.Any())
                            {
                                <div class="ep-application-list">
                                    @foreach (var application in VolunteerApplications)
                                    {
                                        <article class="ep-application-card">
                                            <div class="ep-application-card__top">
                                                <div>
                                                    <strong>@GetUserFullName(application.IdUsuarioNavigation)</strong>
                                                    <p>@application.IdUsuarioNavigation.Email</p>
                                                </div>
                                                <span class="ep-application-status @GetVolunteerStatusClass(application.Estado)">@application.Estado</span>
                                            </div>
                                            <p><strong>Categoría:</strong> @application.CategoriaVoluntariado</p>
                                            <p><strong>Días:</strong> @application.DiasDisponibles</p>
                                            <p><strong>Fecha:</strong> @application.FechaInscripcion.ToString("dd/MM/yyyy hh:mm tt")</p>

                                            @if (string.Equals(application.Estado, "Pendiente", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <div class="ep-application-actions">
                                                    <button type="button"
                                                            class="bulma-button bulma-is-success"
                                                            disabled="@IsReviewingVolunteerRequest"
                                                            @onclick="() => ApproveVolunteerApplicationAsync(application.Id)">
                                                        Aprobar
                                                    </button>
                                                    <button type="button"
                                                            class="bulma-button bulma-is-danger is-light"
                                                            disabled="@IsReviewingVolunteerRequest"
                                                            @onclick="() => RejectVolunteerApplicationAsync(application.Id)">
                                                        Rechazar
                                                    </button>
                                                </div>
                                            }
                                            else if (CanRemoveVolunteerRole(application))
                                            {
                                                <div class="ep-application-actions">
                                                    <button type="button"
                                                            class="bulma-button bulma-is-danger bulma-is-light"
                                                            disabled="@IsReviewingVolunteerRequest"
                                                            @onclick="() => RemoveVolunteerRoleAsync(application.Id)">
                                                        Quitar rol de voluntario
                                                    </button>
                                                </div>
                                            }
                                        </article>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="ep-field-note">Este programa todavía no tiene postulaciones de voluntariado.</p>
                            }
                        </section>
                    }

                    <section class="ep-card">
                        <h2 class="ep-card__title">
                            <span class="ep-card__title-icon ep-card__title-icon--yellow">
                                <i class="fas fa-circle-info"></i>
                            </span>
                            Información adicional
                        </h2>

                        <div class="ep-summary-grid">
                            <article class="ep-summary-item">
                                <span class="ep-summary-item__label">Fecha de creación</span>
                                <strong class="ep-summary-item__value">@CurrentProgram?.FechaCreacion.ToString("dd/MM/yyyy")</strong>
                            </article>
                            <article class="ep-summary-item">
                                <span class="ep-summary-item__label">Categoría actual</span>
                                <strong class="ep-summary-item__value">@CurrentProgram?.IdCategoriaNavigation?.Nombre</strong>
                            </article>
                            <article class="ep-summary-item">
                                <span class="ep-summary-item__label">Estado del programa</span>
                                <strong class="ep-summary-item__value">@CurrentProgram?.Estado</strong>
                            </article>
                        </div>
                    </section>
                </div>

                <aside class="ep-sidebar">
                    <div class="ep-tips-card">
                        <h3 class="ep-tips-card__title">
                            <span class="ep-tips-card__icon"><i class="far fa-lightbulb"></i></span>
                            Recomendaciones
                        </h3>
                        <ol class="ep-tips-list">
                            <li class="ep-tips-list__item">
                                <span class="ep-tips-list__num">1</span>
                                <div>
                                    <strong>Sea claro:</strong>
                                    <p>Explique el objetivo del programa y su impacto esperado para la comunidad.</p>
                                </div>
                            </li>
                            <li class="ep-tips-list__item">
                                <span class="ep-tips-list__num">2</span>
                                <div>
                                    <strong>Alinee la categoría:</strong>
                                    <p>Use la categoría correcta para mejorar la búsqueda y el filtrado de programas.</p>
                                </div>
                            </li>
                            <li class="ep-tips-list__item">
                                <span class="ep-tips-list__num">3</span>
                                <div>
                                    <strong>Revise la meta:</strong>
                                    <p>Mantenga una meta financiera coherente con el alcance real del programa.</p>
                                </div>
                            </li>
                        </ol>
                    </div>
                </aside>
            </div>

            <div class="ep-action-bar">
                <button type="button" class="ep-action-bar__cancel" @onclick="HandleCancel">Cancelar</button>
                <button type="submit" class="bulma-button bulma-is-warning ep-btn-update" disabled="@IsSaving">
                    <span class="bulma-icon bulma-is-small"><i class="fas fa-floppy-disk"></i></span>
                    <strong>@(IsSaving ? "Actualizando..." : "Actualizar programa")</strong>
                </button>
            </div>
        </EditForm>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private const int MaxWords = 500;

    private Usuario? CurrentUser { get; set; }
    private Programa? CurrentProgram { get; set; }
    private EditProgramModel? FormModel { get; set; }
    private List<Categoria> Categories { get; set; } = new();
    private List<InscripcionesVoluntario> VolunteerApplications { get; set; } = new();
    private bool IsLoading { get; set; } = true;
    private bool IsSaving { get; set; }
    private bool IsReviewingVolunteerRequest { get; set; }
    private string? ErrorMessage { get; set; }
    private string? VolunteerReviewMessage { get; set; }
    private bool VolunteerReviewSuccess { get; set; }
    private static readonly IReadOnlyList<string> VolunteerDayOptions = new[]
    {
        "Lunes",
        "Martes",
        "Miércoles",
        "Jueves",
        "Viernes",
        "Sábado",
        "Domingo"
    };

    private int WordCount => string.IsNullOrWhiteSpace(FormModel?.Description)
        ? 0
        : FormModel.Description.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries).Length;

    protected override async Task OnInitializedAsync()
    {
        await LoadPageAsync();
    }

    private async Task LoadPageAsync()
    {
        try
        {
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity is null || !user.Identity.IsAuthenticated)
            {
                Navigation.NavigateTo("/");
                return;
            }

            var userIdStr = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (!int.TryParse(userIdStr, out var userId))
            {
                Navigation.NavigateTo("/");
                return;
            }

            CurrentUser = await UsuarioService.ObtenerPorId(userId);
            if (!IsAdmin(CurrentUser))
            {
                Navigation.NavigateTo("/");
                return;
            }

            Categories = await CasoService.ObtenerCategorias();
            CurrentProgram = await ProgramaService.ObtenerPorIdConDetallesAsync(Id);
            VolunteerApplications = await ProgramaService.ObtenerInscripcionesVoluntariadoPorProgramaAsync(Id);

            if (CurrentProgram is null)
            {
                ErrorMessage = "No se encontró el programa solicitado.";
                return;
            }

            FormModel = new EditProgramModel
            {
                ProgramTitle = CurrentProgram.Nombre,
                CategoryId = CurrentProgram.IdCategoria,
                Description = CurrentProgram.Descripcion,
                ProgramType = CurrentProgram.TipoPrograma,
                Status = CurrentProgram.Estado,
                RequiredAmount = CurrentProgram.MetaFinanciera,
                VolunteerGoal = CurrentProgram.MetaVoluntarios,
                VolunteerDays = ParseDays(CurrentProgram.DiasVoluntariado)
            };
        }
        catch (Exception ex)
        {
            ErrorMessage = "Ocurrió un error al cargar el programa: " + ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void HandleCancel()
    {
        Navigation.NavigateTo("/admin/programs");
    }

    private async Task HandleUpdateAsync()
    {
        if (FormModel is null || CurrentProgram is null)
        {
            return;
        }

        ErrorMessage = null;
        IsSaving = true;

        try
        {
            CurrentProgram.Nombre = FormModel.ProgramTitle.Trim();
            CurrentProgram.Descripcion = FormModel.Description.Trim();
            CurrentProgram.IdCategoria = FormModel.CategoryId ?? CurrentProgram.IdCategoria;
            CurrentProgram.TipoPrograma = FormModel.ProgramType;
            CurrentProgram.Estado = FormModel.Status;
            CurrentProgram.MetaFinanciera = SupportsFinancialGoal(FormModel.ProgramType) ? FormModel.RequiredAmount ?? 0m : 0m;
            CurrentProgram.MetaVoluntarios = SupportsVolunteerGoal(FormModel.ProgramType) ? FormModel.VolunteerGoal ?? 0 : 0;
            CurrentProgram.DiasVoluntariado = SupportsVolunteerGoal(FormModel.ProgramType)
                ? string.Join(", ", FormModel.VolunteerDays)
                : null;

            await ProgramaService.ActualizarAsync(CurrentProgram);
            Navigation.NavigateTo("/admin/programs");
        }
        catch (Exception ex)
        {
            ErrorMessage = "No se pudo actualizar el programa: " + ex.Message;
        }
        finally
        {
            IsSaving = false;
        }
    }

    private async Task ApproveVolunteerApplicationAsync(int applicationId)
    {
        await ReviewVolunteerApplicationAsync(applicationId, isApproval: true);
    }

    private async Task RejectVolunteerApplicationAsync(int applicationId)
    {
        await ReviewVolunteerApplicationAsync(applicationId, isApproval: false);
    }

    private async Task RemoveVolunteerRoleAsync(int applicationId)
    {
        IsReviewingVolunteerRequest = true;
        VolunteerReviewMessage = null;

        try
        {
            await ProgramaService.RemoverVoluntarioPorIncumplimientoAsync(applicationId);
            VolunteerReviewSuccess = true;
            VolunteerReviewMessage = "El voluntario fue removido del programa por incumplimiento y su rol volvio a Donante.";
            VolunteerApplications = await ProgramaService.ObtenerInscripcionesVoluntariadoPorProgramaAsync(Id);
            CurrentProgram = await ProgramaService.ObtenerPorIdConDetallesAsync(Id);
        }
        catch (Exception ex)
        {
            VolunteerReviewSuccess = false;
            VolunteerReviewMessage = "No se pudo quitar el rol de voluntario: " + ex.Message;
        }
        finally
        {
            IsReviewingVolunteerRequest = false;
        }
    }

    private async Task ReviewVolunteerApplicationAsync(int applicationId, bool isApproval)
    {
        IsReviewingVolunteerRequest = true;
        VolunteerReviewMessage = null;

        try
        {
            if (isApproval)
            {
                await ProgramaService.AprobarInscripcionVoluntariadoAsync(applicationId);
                VolunteerReviewMessage = "La solicitud fue aprobada y el usuario pasó a rol de voluntario.";
            }
            else
            {
                await ProgramaService.RechazarInscripcionVoluntariadoAsync(applicationId);
                VolunteerReviewMessage = "La solicitud fue rechazada y el usuario puede postularse a otro programa.";
            }

            VolunteerReviewSuccess = true;
            VolunteerApplications = await ProgramaService.ObtenerInscripcionesVoluntariadoPorProgramaAsync(Id);
            CurrentProgram = await ProgramaService.ObtenerPorIdConDetallesAsync(Id);
        }
        catch (Exception ex)
        {
            VolunteerReviewSuccess = false;
            VolunteerReviewMessage = "No se pudo procesar la solicitud: " + ex.Message;
        }
        finally
        {
            IsReviewingVolunteerRequest = false;
        }
    }

    private void ToggleVolunteerDay(string day, bool isSelected)
    {
        if (FormModel is null)
        {
            return;
        }

        if (isSelected)
        {
            if (!FormModel.VolunteerDays.Contains(day))
            {
                FormModel.VolunteerDays.Add(day);
            }

            return;
        }

        FormModel.VolunteerDays.Remove(day);
    }

    private static List<string> ParseDays(string? rawDays)
    {
        return string.IsNullOrWhiteSpace(rawDays)
            ? new List<string>()
            : rawDays
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();
    }

    private static string GetUserFullName(Usuario? usuario)
    {
        return usuario is null
            ? "Usuario"
            : $"{usuario.Nombre} {usuario.Apellido}".Trim();
    }

    private static string GetVolunteerStatusClass(string? status)
    {
        return status switch
        {
            "Aprobado" => "ep-application-status--approved",
            "Pendiente" => "ep-application-status--pending",
            "Activo" => "ep-application-status--approved",
            _ => "ep-application-status--rejected"
        };
    }

    private static bool CanRemoveVolunteerRole(InscripcionesVoluntario application)
    {
        return string.Equals(application.Estado, "Aprobado", StringComparison.OrdinalIgnoreCase) ||
               string.Equals(application.Estado, "Activo", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsAdmin(Usuario? usuario)
    {
        var roleName = usuario?.IdRolNavigation?.Nombre;
        return !string.IsNullOrWhiteSpace(roleName) &&
               roleName.Equals("Administrador", StringComparison.OrdinalIgnoreCase);
    }

    private static bool SupportsFinancialGoal(string? tipoPrograma)
    {
        return string.Equals(tipoPrograma, "Financiero", StringComparison.OrdinalIgnoreCase) ||
               string.Equals(tipoPrograma, "Hibrido", StringComparison.OrdinalIgnoreCase);
    }

    private static bool SupportsVolunteerGoal(string? tipoPrograma)
    {
        return string.Equals(tipoPrograma, "Voluntariado", StringComparison.OrdinalIgnoreCase) ||
               string.Equals(tipoPrograma, "Hibrido", StringComparison.OrdinalIgnoreCase);
    }

    private sealed class EditProgramModel : IValidatableObject
    {
        [Required(ErrorMessage = "El nombre es obligatorio.")]
        [StringLength(120, ErrorMessage = "El nombre no puede exceder 120 caracteres.")]
        public string ProgramTitle { get; set; } = string.Empty;

        [Required(ErrorMessage = "Seleccione una categoría.")]
        public int? CategoryId { get; set; }

        [Required(ErrorMessage = "La descripción es obligatoria.")]
        [StringLength(3000, ErrorMessage = "La descripción no puede exceder 3000 caracteres.")]
        public string Description { get; set; } = string.Empty;

        [Required(ErrorMessage = "Seleccione el tipo de programa.")]
        public string ProgramType { get; set; } = "Financiero";

        [Required(ErrorMessage = "Seleccione el estado del programa.")]
        public string Status { get; set; } = "Activo";

        public decimal? RequiredAmount { get; set; }

        public int? VolunteerGoal { get; set; }

        public List<string> VolunteerDays { get; set; } = new();

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            if (SupportsFinancialGoal(ProgramType) && (!RequiredAmount.HasValue || RequiredAmount <= 0))
            {
                yield return new ValidationResult(
                    "Ingrese una meta financiera válida.",
                    new[] { nameof(RequiredAmount) });
            }

            if (SupportsVolunteerGoal(ProgramType) && (!VolunteerGoal.HasValue || VolunteerGoal <= 0))
            {
                yield return new ValidationResult(
                    "Ingrese una meta de voluntarios válida.",
                    new[] { nameof(VolunteerGoal) });
            }

            if (SupportsVolunteerGoal(ProgramType) && VolunteerDays.Count == 0)
            {
                yield return new ValidationResult(
                    "Seleccione al menos un día de voluntariado.",
                    new[] { nameof(VolunteerDays) });
            }
        }
    }
}
