@*
  AdminDonations.razor
  Proposito: Vista administrativa de analitica para ingresos, donadores y categorias de donacion.
*@
@page "/admin/donations"
@layout ProfileLayout
@using Microsoft.EntityFrameworkCore
@using ProyectoSocioEconomico.Application.Interfaces
@using ProyectoSocioEconomico.Domain.Entities
@using ProyectoSocioEconomico.Infrastructure.Data
@using ProyectoSocioEconomico.WebUI.Services
@using System.Globalization
@using System.Security.Claims
@inject AppDbContext DbContext
@inject IUsuarioService UsuarioService
@inject CustomAuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation

<div class="da-page">
    @if (IsLoading)
    {
        <div class="da-state-card">
            <h1 class="da-state-card__title">Cargando analitica...</h1>
            <p class="da-state-card__text">Estamos procesando el resumen de ingresos y donadores.</p>
        </div>
    }
    else
    {
        <section class="da-hero bulma-box">
            <div>
                <p class="da-hero__eyebrow">ADMINISTRACION FINANCIERA</p>
                <h1 class="da-hero__title">Panel de donaciones</h1>
                <p class="da-hero__subtitle">Supervise ingresos, comportamiento de donadores y rendimiento por categoria desde un solo lugar.</p>
            </div>

            <a href="/admin/donations/activities" class="bulma-button bulma-is-warning da-hero__action">
                <strong>Ver todas las actividades</strong>
            </a>
        </section>

        <section class="da-metrics">
            <article class="da-metric-card bulma-box">
                <span class="da-metric-card__icon da-metric-card__icon--gold">
                    <i class="fas fa-sack-dollar"></i>
                </span>
                <div>
                    <p class="da-metric-card__label">Ingresos totales</p>
                    <strong class="da-metric-card__value">@FormatCurrency(TotalIncome)</strong>
                    <p class="da-metric-card__sub">Suma de todas las donaciones completadas.</p>
                </div>
            </article>

            <article class="da-metric-card bulma-box">
                <span class="da-metric-card__icon da-metric-card__icon--blue">
                    <i class="fas fa-coins"></i>
                </span>
                <div>
                    <p class="da-metric-card__label">Promedio por donacion</p>
                    <strong class="da-metric-card__value">@FormatCurrency(AverageDonationAmount)</strong>
                    <p class="da-metric-card__sub">Monto promedio que se aporta por transaccion.</p>
                </div>
            </article>

            <article class="da-metric-card bulma-box">
                <span class="da-metric-card__icon da-metric-card__icon--green">
                    <i class="fas fa-user-group"></i>
                </span>
                <div>
                    <p class="da-metric-card__label">Donadores activos</p>
                    <strong class="da-metric-card__value">@DonorCount</strong>
                    <p class="da-metric-card__sub">Usuarios unicos que ya han donado.</p>
                </div>
            </article>
        </section>

        <section class="da-grid">
            <article class="da-panel da-panel--chart bulma-box">
                <div class="da-panel__header">
                    <div>
                        <h2 class="da-panel__title">Donaciones por categoria</h2>
                        <p class="da-panel__subtitle">Cada barra representa el monto acumulado por categoria, sin importar si la donacion fue a un caso o a un programa.</p>
                    </div>
                    <span class="da-panel__badge">@CategoryBreakdown.Count categorias</span>
                </div>

                @if (CategoryBreakdown.Any(item => item.Amount > 0))
                {
                    <div class="da-bar-chart">
                        <svg viewBox="0 0 760 360" class="da-bar-chart__svg" role="img" aria-label="Grafica de barras de donaciones por categoria">
                            @foreach (var line in CategoryChartGridLines)
                            {
                                <line x1="68" y1="@line.Y" x2="724" y2="@line.Y" class="da-bar-chart__grid-line" />
                                <svg:text x="10" y="@(line.Y + 5)" class="da-bar-chart__axis-text">@line.Label</svg:text>
                            }

                            <line x1="68" y1="300" x2="724" y2="300" class="da-bar-chart__axis-line" />

                            @foreach (var bar in CategoryChartBars)
                            {
                                <rect x="@bar.X"
                                      y="@bar.Y"
                                      width="@bar.Width"
                                      height="@bar.Height"
                                      rx="10"
                                      class="da-bar-chart__bar"
                                      style="fill:@bar.ColorHex;stroke:@bar.ColorStrokeHex;" />
                                <svg:text x="@(bar.X + bar.Width / 2)" y="@(bar.Y - 10)" class="da-bar-chart__value-text" style="fill:@bar.ColorStrokeHex;">
                                    @FormatCompactCurrency(bar.Amount)
                                </svg:text>
                                <svg:text x="@(bar.X + bar.Width / 2)" y="324" class="da-bar-chart__label-text">
                                    @bar.Label
                                </svg:text>
                            }
                        </svg>

                        <div class="da-bar-chart__legend">
                            @foreach (var item in CategoryBreakdown)
                            {
                                <article class="da-bar-chart__legend-item" style="border-top:4px solid @item.ColorHex;">
                                    <strong>@item.CategoryName</strong>
                                    <span>@FormatCurrency(item.Amount)</span>
                                </article>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="da-empty-state">
                        No hay categorias con donaciones registradas todavia.
                    </div>
                }
            </article>
        </section>

        <section class="da-panel bulma-box">
            <div class="da-panel__header">
                <div>
                    <h2 class="da-panel__title">Donadores con mayor aporte</h2>
                    <p class="da-panel__subtitle">Resumen de las personas que mas han aportado a casos y programas con donaciones.</p>
                </div>
                <a href="/admin/donations/activities" class="da-link-action">
                    Ver todas las actividades
                </a>
            </div>

            <div class="da-table-wrap">
                <table class="bulma-table da-table bulma-is-fullwidth">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Categoria</th>
                            <th>Cantidad (Total Donado)</th>
                            <th>Voluntario</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (TopDonors.Any())
                        {
                            @foreach (var donor in TopDonors)
                            {
                                <tr>
                                    <td>
                                        <strong>@donor.Name</strong>
                                        <div class="da-table__detail">@donor.Email</div>
                                    </td>
                                    <td>@donor.TopCategory</td>
                                    <td>@FormatCurrency(donor.TotalAmount)</td>
                                    <td>
                                        <span class="da-pill @(donor.IsVolunteer ? "da-pill--success" : "da-pill--muted")">
                                            @(donor.IsVolunteer ? "Si" : "No")
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="da-table__empty">No hay donadores para mostrar.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>

@code {
    private static readonly CultureInfo CurrencyCulture = CultureInfo.GetCultureInfo("es-SV");

    private Usuario? CurrentUser { get; set; }
    private bool IsLoading { get; set; } = true;
    private decimal TotalIncome { get; set; }
    private decimal AverageDonationAmount { get; set; }
    private int DonorCount { get; set; }
    private List<CategoryBreakdownItem> CategoryBreakdown { get; set; } = new();
    private List<TopDonorItem> TopDonors { get; set; } = new();

    private List<ChartGridLine> CategoryChartGridLines => BuildCategoryChartGridLines();
    private List<CategoryChartBar> CategoryChartBars => BuildCategoryChartBars();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity is null || !user.Identity.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        var userIdStr = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (!int.TryParse(userIdStr, out var userId))
        {
            Navigation.NavigateTo("/");
            return;
        }

        CurrentUser = await UsuarioService.ObtenerPorId(userId);
        if (!IsAdmin(CurrentUser))
        {
            Navigation.NavigateTo("/");
            return;
        }

        await LoadAnalyticsAsync();
    }

    private async Task LoadAnalyticsAsync()
    {
        try
        {
            var completedDonations = await DbContext.Donaciones
                .AsNoTracking()
                .Include(d => d.IdDonadorNavigation)
                .Include(d => d.IdCasoNavigation)
                    .ThenInclude(c => c.IdCategoriaNavigation)
                .Include(d => d.IdProgramaNavigation)
                    .ThenInclude(p => p.IdCategoriaNavigation)
                .Where(d => d.Estado == "Completado")
                .ToListAsync();

            var volunteerUserIds = await DbContext.InscripcionesVoluntarios
                .AsNoTracking()
                .Where(v => v.Estado == "Aprobado" || v.Estado == "Activo")
                .Select(v => v.IdUsuario)
                .Distinct()
                .ToListAsync();

            TotalIncome = completedDonations.Sum(donation => donation.Monto);
            AverageDonationAmount = completedDonations.Count == 0
                ? 0m
                : completedDonations.Average(donation => donation.Monto);
            DonorCount = completedDonations
                .Select(donation => donation.IdDonador)
                .Distinct()
                .Count();

            CategoryBreakdown = BuildCategoryBreakdown(completedDonations);
            TopDonors = BuildTopDonors(completedDonations, volunteerUserIds, 5);
        }
        finally
        {
            IsLoading = false;
        }
    }

    private static List<CategoryBreakdownItem> BuildCategoryBreakdown(List<Donacione> donations)
    {
        var total = donations.Sum(donation => donation.Monto);
        if (total <= 0)
        {
            return new List<CategoryBreakdownItem>();
        }

        return donations
            .GroupBy(GetCategoryName)
            .Select(group => new CategoryBreakdownItem(
                group.Key,
                group.Sum(item => item.Monto),
                group.Sum(item => item.Monto) / total * 100m,
                GetCategoryColor(group.Key),
                GetCategoryStrokeColor(group.Key)))
            .OrderByDescending(item => item.Amount)
            .ToList();
    }

    private static List<TopDonorItem> BuildTopDonors(List<Donacione> donations, List<int> volunteerUserIds, int take)
    {
        return donations
            .GroupBy(donation => new
            {
                donation.IdDonador,
                Name = GetDonorName(donation.IdDonadorNavigation),
                donation.IdDonadorNavigation.Email
            })
            .Select(group =>
            {
                var category = group
                    .GroupBy(GetCategoryName)
                    .OrderByDescending(categoryGroup => categoryGroup.Sum(item => item.Monto))
                    .ThenBy(categoryGroup => categoryGroup.Key)
                    .Select(categoryGroup => categoryGroup.Key)
                    .FirstOrDefault() ?? "Sin categoria";

                return new TopDonorItem(
                    group.Key.IdDonador,
                    group.Key.Name,
                    group.Key.Email ?? "Sin correo",
                    group.Sum(item => item.Monto),
                    category,
                    volunteerUserIds.Contains(group.Key.IdDonador));
            })
            .OrderByDescending(item => item.TotalAmount)
            .ThenBy(item => item.Name)
            .Take(take)
            .ToList();
    }

    private List<ChartGridLine> BuildCategoryChartGridLines()
    {
        const decimal fallbackMax = 100m;
        const int totalLines = 4;
        var maxAmount = CategoryBreakdown.Count == 0 ? fallbackMax : Math.Max(CategoryBreakdown.Max(point => point.Amount), fallbackMax);

        return Enumerable.Range(0, totalLines)
            .Select(index =>
            {
                var ratio = index / (decimal)(totalLines - 1);
                var y = 52 + (1 - ratio) * 220;
                var amount = maxAmount * ratio;

                return new ChartGridLine(
                    (double)y,
                    FormatCurrency(amount));
            })
            .OrderByDescending(item => item.Y)
            .ToList();
    }

    private List<CategoryChartBar> BuildCategoryChartBars()
    {
        if (CategoryBreakdown.Count == 0)
        {
            return new List<CategoryChartBar>();
        }

        const double startX = 96;
        const double totalWidth = 580;
        const double baseY = 300;
        const double chartHeight = 220;
        const double gap = 22;
        var maxAmount = Math.Max(CategoryBreakdown.Max(point => point.Amount), 100m);
        var barCount = CategoryBreakdown.Count;
        var barWidth = barCount == 0 ? 0 : Math.Max(36, (totalWidth - gap * (barCount - 1)) / barCount);

        return CategoryBreakdown
            .Select((point, index) =>
            {
                var height = (double)(point.Amount / maxAmount) * chartHeight;
                var x = startX + index * (barWidth + gap);
                var y = baseY - height;

                return new CategoryChartBar(
                    x,
                    y,
                    barWidth,
                    height,
                    point.CategoryName,
                    point.Amount,
                    point.ColorHex,
                    point.ColorStrokeHex);
            })
            .ToList();
    }

    private static string GetCategoryName(Donacione donation)
    {
        return donation.IdCasoNavigation?.IdCategoriaNavigation?.Nombre
            ?? donation.IdProgramaNavigation?.IdCategoriaNavigation?.Nombre
            ?? "Sin categoria";
    }

    private static string GetDonorName(Usuario? user)
    {
        if (user is null)
        {
            return "Donador no disponible";
        }

        return $"{user.Nombre} {user.Apellido}".Trim();
    }

    private static bool IsAdmin(Usuario? usuario)
    {
        var roleName = usuario?.IdRolNavigation?.Nombre;
        return !string.IsNullOrWhiteSpace(roleName) &&
               roleName.Equals("Administrador", StringComparison.OrdinalIgnoreCase);
    }

    private static string GetCategoryColor(string categoryName)
    {
        return NormalizeCategoryName(categoryName) switch
        {
            "salud" => "#ef4444",
            "educacion" => "#3b82f6",
            "infraestructura" => "#8b5cf6",
            "desastres naturales" => "#f59e0b",
            "naturaleza" => "#22c55e",
            _ => "#14b8a6"
        };
    }

    private static string GetCategoryStrokeColor(string categoryName)
    {
        return NormalizeCategoryName(categoryName) switch
        {
            "salud" => "#b91c1c",
            "educacion" => "#1d4ed8",
            "infraestructura" => "#6d28d9",
            "desastres naturales" => "#b45309",
            "naturaleza" => "#15803d",
            _ => "#0f766e"
        };
    }

    private static string NormalizeCategoryName(string categoryName)
    {
        return categoryName.Trim().ToLowerInvariant();
    }

    private static string FormatCurrency(decimal amount)
    {
        return amount.ToString("C", CurrencyCulture);
    }

    private static string FormatCompactCurrency(decimal amount)
    {
        if (amount >= 1000000m)
        {
            return $"{amount / 1000000m:0.#}M";
        }

        if (amount >= 1000m)
        {
            return $"{amount / 1000m:0.#}K";
        }

        return amount.ToString("0", CultureInfo.InvariantCulture);
    }

    private sealed record CategoryBreakdownItem(string CategoryName, decimal Amount, decimal Percentage, string ColorHex, string ColorStrokeHex);
    private sealed record TopDonorItem(int DonorId, string Name, string Email, decimal TotalAmount, string TopCategory, bool IsVolunteer);
    private sealed record ChartGridLine(double Y, string Label);
    private sealed record CategoryChartBar(double X, double Y, double Width, double Height, string Label, decimal Amount, string ColorHex, string ColorStrokeHex);
}
