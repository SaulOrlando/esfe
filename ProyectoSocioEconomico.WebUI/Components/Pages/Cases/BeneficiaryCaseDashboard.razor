@namespace ProyectoSocioEconomico.WebUI.Components.Pages
@*
  BeneficiaryCaseDashboard.razor
  Proposito: Dashboard del beneficiario con gestion de caso y solicitudes de retiro.
*@
@page "/beneficiary/dashboard"
@layout ProfileLayout
@using ProyectoSocioEconomico.Domain.Entities
@using ProyectoSocioEconomico.Application.Interfaces
@using System.ComponentModel.DataAnnotations
@using System.Globalization
@inject ICasoService CasoService
@inject IRetiroService RetiroService
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider

<div class="bw-page">
    <main class="bw-main">
        <div class="bw-main__header">
            <div>
                <h1 class="bw-main__title">Mi Panel de Beneficiario</h1>
                <p class="bw-main__subtitle">Monitorea el progreso de tus campañas y gestiona tus fondos.</p>
            </div>
        </div>

        @if (Cases == null)
        {
            <div class="bw-card" style="text-align:center; padding: 4rem;">
                <p class="bw-main__subtitle">Cargando datos del panel...</p>
            </div>
        }
        else if (!Cases.Any())
        {
            <div class="bw-card" style="text-align:center; padding: 5rem 2rem;">
                <div style="font-size: 4rem; color: var(--bw-text-muted); margin-bottom: 1.5rem;">
                    <i class="fas fa-folder-open"></i>
                </div>
                <h2 class="bw-main__title" style="font-size: 1.5rem;">Aun no tienes campañas</h2>
                <p class="bw-main__subtitle">Comienza hoy mismo a recaudar fondos para tu causa.</p>
            </div>
        }
        else
        {
            <div class="bw-stats-grid">
                <div class="bw-stat-card">
                    <div class="bw-stat-card__icon" style="color: var(--bw-green);"><i class="fas fa-hand-holding-dollar"></i></div>
                    <span class="bw-stat-card__label">Total Recaudado</span>
                    <span class="bw-stat-card__value">@totalRecaudado.ToString("C", CultureInfo.GetCultureInfo("es-SV"))</span>
                </div>
                <div class="bw-stat-card">
                    <div class="bw-stat-card__icon" style="color: var(--bw-yellow);"><i class="fas fa-bullseye"></i></div>
                    <span class="bw-stat-card__label">Meta del Caso</span>
                    <span class="bw-stat-card__value">@metaTotal.ToString("C", CultureInfo.GetCultureInfo("es-SV"))</span>
                </div>
                <div class="bw-stat-card">
                    <div class="bw-stat-card__icon" style="color: #ef4444;"><i class="fas fa-hourglass-half"></i></div>
                    <span class="bw-stat-card__label">Restante</span>
                    <span class="bw-stat-card__value">@restante.ToString("C", CultureInfo.GetCultureInfo("es-SV"))</span>
                </div>
                <div class="bw-stat-card">
                    <div class="bw-stat-card__icon" style="color: #3b82f6;"><i class="fas fa-users"></i></div>
                    <span class="bw-stat-card__label">Donantes</span>
                    <span class="bw-stat-card__value">@totalDonantes</span>
                </div>
            </div>

            <div class="bw-card">
                <h2 class="bw-section-title"><i class="fas fa-list-check"></i> Gestion de Campañas</h2>

                <div style="display: flex; flex-direction: column; gap: 1.5rem; margin-top: 1rem;">
                    @foreach (var c in Cases)
                    {
                        var pct = metaTotal > 0 ? (int)Math.Round((totalRecaudado / metaTotal) * 100) : 0;
                        <div style="border: 1px solid var(--bw-border); border-radius: 12px; padding: 1.5rem; display: flex; justify-content: space-between; align-items: center; gap: 2rem;">
                            <div style="flex: 1;">
                                <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
                                    <h3 style="font-size: 1.2rem; font-weight: 700; margin:0;">@c.Titulo</h3>
                                    <span style="font-size: 0.7rem; font-weight: 800; padding: 0.2rem 0.6rem; border-radius: 99px; background: #e0f2fe; color: #0369a1; text-transform: uppercase;">
                                        @c.Estado
                                    </span>
                                </div>
                                <p style="font-size: 0.9rem; color: var(--bw-text-mid); margin-bottom: 1rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                    @c.Descripcion
                                </p>
                                <div style="display: flex; align-items: center; gap: 1rem;">
                                    <div style="flex: 1; height: 8px; background: #eee; border-radius: 4px; overflow: hidden;">
                                        <div style="width: @(pct)%; height: 100%; background: var(--bw-green);"></div>
                                    </div>
                                    <span style="font-size: 0.85rem; font-weight: 700; color: var(--bw-text-mid);">@pct%</span>
                                </div>
                            </div>

                            <div style="display: flex; gap: 0.75rem;">
                                <a href="/cases/@c.Id" class="bw-btn-edit">
                                    <i class="fas fa-eye"></i> Ver
                                </a>
                                @if (c.Estado == "Activo")
                                {
                                    <button type="button"
                                            class="bw-btn-edit"
                                            style="background: white; border-color: var(--bw-border);"
                                            @onclick="@(() => NavigateToEditCase(c.Id))"
                                            aria-label="Editar caso">
                                        <i class="fas fa-pen"></i>
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="bw-card bw-withdrawal-card" style="border-left: 5px solid var(--bw-green); color: #1a1a1a;">
                @if (!string.IsNullOrWhiteSpace(withdrawalErrorMessage))
                {
                    <div class="bulma-notification bulma-is-danger bulma-is-light" style="margin-bottom: 1rem; color: #1a1a1a;">
                        @withdrawalErrorMessage
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(withdrawalStatusMessage))
                {
                    <div class="bulma-notification bulma-is-success bulma-is-light" style="margin-bottom: 1rem; color: #1a1a1a;">
                        @withdrawalStatusMessage
                    </div>
                }

                <div style="display: flex; justify-content: space-between; align-items: center; gap: 2rem; flex-wrap: wrap;">
                    <div>
                        <h2 class="bw-section-title" style="margin-bottom: 0.5rem; color: #1a1a1a;"><i class="fas fa-wallet"></i> Fondos Disponibles</h2>
                        <p class="bw-main__subtitle" style="color: #1a1a1a;">@withdrawalHelperText</p>
                    </div>
                    <div style="text-align: right;">
                        <div style="font-size: 2rem; font-weight: 900; color: var(--bw-green);">@availableBalance.ToString("C", CultureInfo.GetCultureInfo("es-SV"))</div>
                        <button type="button"
                                class="bw-btn-withdraw"
                                style="margin-top: 0.5rem; height: 2.8rem; font-size: 0.95rem; padding: 0 1.5rem;"
                                @onclick="StartWithdrawalRequest"
                                disabled="@(!canRequestWithdrawal || isSubmittingWithdrawal)">
                            Solicitar Retiro
                        </button>
                    </div>
                </div>

                @if (showWithdrawalForm)
                {
                    <div class="bw-withdrawal-form" style="margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--bw-border); color: #1a1a1a;">
                        <EditForm Model="WithdrawalForm" OnValidSubmit="HandleRequestWithdrawalAsync" FormName="WithdrawalRequestForm">
                            <DataAnnotationsValidator />
                            <ValidationSummary class="bulma-help bulma-is-danger bw-withdrawal-form__summary" style="color: #b42318;" />

                            <div class="bulma-columns bulma-is-variable bulma-is-4">
                                <div class="bulma-column bulma-is-6-tablet bulma-is-4-desktop">
                                    <div class="bulma-field">
                                        <label class="bulma-label" style="color: #1a1a1a;">Monto a retirar</label>
                                        <div class="bulma-control">
                                            <InputNumber class="bulma-input bw-withdrawal-form__input" style="color: #1a1a1a; background-color: #ffffff;" @bind-Value="WithdrawalForm.Amount" />
                                        </div>
                                        <ValidationMessage For="@(() => WithdrawalForm.Amount)" class="bulma-help bulma-is-danger" />
                                        <p class="bulma-help" style="color: #1a1a1a;">Disponible: @availableBalance.ToString("C", CultureInfo.GetCultureInfo("es-SV"))</p>
                                    </div>
                                </div>

                                <div class="bulma-column bulma-is-6-tablet bulma-is-4-desktop">
                                    <div class="bulma-field">
                                        <label class="bulma-label" style="color: #1a1a1a;">Metodo de retiro</label>
                                        <div class="bulma-control">
                                            <div class="bulma-select bulma-is-fullwidth">
                                                <InputSelect class="bw-withdrawal-form__select" style="color: #1a1a1a; background-color: #ffffff;" @bind-Value="WithdrawalForm.PaymentMethod">
                                                    <option value="">Seleccione un metodo</option>
                                                    <option value="PayPal">PayPal</option>
                                                    <option value="Transferencia">Transferencia</option>
                                                </InputSelect>
                                            </div>
                                        </div>
                                        <ValidationMessage For="@(() => WithdrawalForm.PaymentMethod)" class="bulma-help bulma-is-danger" />
                                    </div>
                                </div>
                            </div>

                            @if (IsTransferPaymentMethod)
                            {
                                <section class="bw-transfer-details">
                                    <div class="bw-transfer-details__header">
                                        <h3 class="bw-transfer-details__title" style="color: #1a1a1a;">Datos bancarios para la transferencia</h3>
                                        <p class="bw-transfer-details__text" style="color: #1a1a1a;">Completa la cuenta donde se depositara el retiro.</p>
                                    </div>

                                    <div class="bulma-columns bulma-is-variable bulma-is-4">
                                        <div class="bulma-column bulma-is-4-desktop bulma-is-6-tablet">
                                            <div class="bulma-field">
                                                <label class="bulma-label" style="color: #1a1a1a;">Nombre del titular</label>
                                                <div class="bulma-control">
                                                    <InputText class="bulma-input bw-transfer-details__input" style="color: #1a1a1a; background-color: #ffffff;" @bind-Value="WithdrawalForm.AccountHolderName" placeholder="Ej. Maria Lopez" />
                                                </div>
                                                <ValidationMessage For="@(() => WithdrawalForm.AccountHolderName)" class="bulma-help bulma-is-danger" />
                                            </div>
                                        </div>

                                        <div class="bulma-column bulma-is-4-desktop bulma-is-6-tablet">
                                            <div class="bulma-field">
                                                <label class="bulma-label" style="color: #1a1a1a;">Numero de Cuenta</label>
                                                <div class="bulma-control">
                                                    <InputText class="bulma-input bw-transfer-details__input" style="color: #1a1a1a; background-color: #ffffff;" @bind-Value="WithdrawalForm.AccountNumber" placeholder="Ej. 1234567890" />
                                                </div>
                                                <ValidationMessage For="@(() => WithdrawalForm.AccountNumber)" class="bulma-help bulma-is-danger" />
                                            </div>
                                        </div>

                                        <div class="bulma-column bulma-is-4-desktop bulma-is-12-tablet">
                                            <div class="bulma-field">
                                                <label class="bulma-label" style="color: #1a1a1a;">Banco</label>
                                                <div class="bulma-control">
                                                    <InputText class="bulma-input bw-transfer-details__input" style="color: #1a1a1a; background-color: #ffffff;" @bind-Value="WithdrawalForm.BankName" placeholder="Ej. Banco Agricola" />
                                                </div>
                                                <ValidationMessage For="@(() => WithdrawalForm.BankName)" class="bulma-help bulma-is-danger" />
                                            </div>
                                        </div>
                                    </div>
                                </section>
                            }
                            else if (IsPayPalPaymentMethod)
                            {
                                <section class="bw-transfer-details bw-transfer-details--paypal">
                                    <div class="bw-transfer-details__header">
                                        <h3 class="bw-transfer-details__title" style="color: #1a1a1a;">Cuenta de PayPal</h3>
                                        <p class="bw-transfer-details__text" style="color: #1a1a1a;">Ingresa el correo asociado a tu cuenta para recibir el retiro.</p>
                                    </div>

                                    <div class="bulma-columns">
                                        <div class="bulma-column bulma-is-8-desktop bulma-is-10-tablet">
                                            <div class="bulma-field">
                                                <label class="bulma-label" style="color: #1a1a1a;">Correo de PayPal</label>
                                                <div class="bulma-control">
                                                    <InputText class="bulma-input bw-transfer-details__input" style="color: #1a1a1a; background-color: #ffffff;" @bind-Value="WithdrawalForm.PayPalEmail" placeholder="correo@paypal.com" />
                                                </div>
                                                <ValidationMessage For="@(() => WithdrawalForm.PayPalEmail)" class="bulma-help bulma-is-danger" />
                                            </div>
                                        </div>
                                    </div>
                                </section>
                            }

                            <div style="display: flex; justify-content: flex-end; gap: 0.75rem; margin-top: 1rem;">
                                <button type="button" class="bulma-button bulma-is-light" @onclick="CancelWithdrawalRequest" disabled="@isSubmittingWithdrawal">
                                    Cancelar
                                </button>
                                <button type="submit" class="bulma-button bulma-is-success" disabled="@isSubmittingWithdrawal">
                                    <strong>@(isSubmittingWithdrawal ? "Enviando..." : "Enviar solicitud")</strong>
                                </button>
                            </div>
                        </EditForm>
                    </div>
                }
            </div>
        }
    </main>
</div>

@code {
    private List<Caso>? Cases;
    private Caso? activeCase;
    private decimal totalRecaudado;
    private decimal metaTotal;
    private decimal restante;
    private decimal availableBalance;
    private int totalDonantes;
    private int currentUserId;
    private bool canRequestWithdrawal;
    private bool hasPendingWithdrawalRequest;
    private bool isSubmittingWithdrawal;
    private bool showWithdrawalForm;
    private const int MaxPaymentDetailsLength = 255;
    private string? withdrawalErrorMessage;
    private string? withdrawalStatusMessage;
    private string withdrawalHelperText = "Puedes solicitar el desembolso de cualquier saldo disponible en tu caso.";
    private WithdrawalRequestModel WithdrawalForm { get; set; } = new();

    private bool IsTransferPaymentMethod =>
        string.Equals(WithdrawalForm.PaymentMethod, "Transferencia", StringComparison.OrdinalIgnoreCase);

    private bool IsPayPalPaymentMethod =>
        string.Equals(WithdrawalForm.PaymentMethod, "PayPal", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var idStr = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (int.TryParse(idStr, out var userId))
        {
            currentUserId = userId;
            Cases = new List<Caso>();
            activeCase = await CasoService.ObtenerPorBeneficiadoIdAsync(userId);

            if (activeCase != null)
            {
                Cases.Add(activeCase);

                totalRecaudado = activeCase.Donaciones?.Where(d => d.Estado == "Completado").Sum(d => d.Monto) ?? 0;
                metaTotal = activeCase.Meta;
                restante = Math.Max(0, metaTotal - totalRecaudado);
                totalDonantes = activeCase.Donaciones?.Count(d => d.Estado == "Completado") ?? 0;

                await LoadWithdrawalStateAsync();
            }
        }
    }

    private void NavigateToEditCase(int caseId)
    {
        Navigation.NavigateTo($"/cases/{caseId}/edit");
    }

    private void StartWithdrawalRequest()
    {
        withdrawalErrorMessage = null;
        withdrawalStatusMessage = null;

        if (!canRequestWithdrawal)
        {
            withdrawalErrorMessage = withdrawalHelperText;
            return;
        }

        WithdrawalForm = new WithdrawalRequestModel
        {
            Amount = availableBalance
        };

        showWithdrawalForm = true;
    }

    private void CancelWithdrawalRequest()
    {
        showWithdrawalForm = false;
        withdrawalErrorMessage = null;
    }

    private async Task HandleRequestWithdrawalAsync()
    {
        withdrawalErrorMessage = null;
        withdrawalStatusMessage = null;

        if (activeCase is null || currentUserId <= 0)
        {
            withdrawalErrorMessage = "No se pudo identificar el caso para solicitar el retiro.";
            return;
        }

        if (!canRequestWithdrawal)
        {
            withdrawalErrorMessage = withdrawalHelperText;
            return;
        }

        isSubmittingWithdrawal = true;

        try
        {
            await LoadWithdrawalStateAsync();

            if (!canRequestWithdrawal)
            {
                withdrawalErrorMessage = withdrawalHelperText;
                return;
            }

            if (WithdrawalForm.Amount <= 0)
            {
                withdrawalErrorMessage = "Debes ingresar un monto mayor que cero.";
                return;
            }

            if (WithdrawalForm.Amount > availableBalance)
            {
                withdrawalErrorMessage = "El monto solicitado no puede ser mayor al saldo disponible.";
                return;
            }

            var paymentDetails = BuildPaymentDetails();
            if (paymentDetails.Length > MaxPaymentDetailsLength)
            {
                withdrawalErrorMessage = "Los datos del metodo de retiro son demasiado largos. Reduce el nombre del titular o el nombre del banco.";
                return;
            }

            await RetiroService.Crear(new Retiro
            {
                IdBeneficiado = currentUserId,
                IdCaso = activeCase.Id,
                Monto = WithdrawalForm.Amount,
                MetodoPago = WithdrawalForm.PaymentMethod.Trim(),
                DatosPago = paymentDetails,
                Estado = "Pendiente",
                FechaSolicitud = DateTime.Now
            });

            showWithdrawalForm = false;
            withdrawalStatusMessage = "La solicitud de retiro fue enviada y quedo pendiente de revision.";
            await LoadWithdrawalStateAsync();
            Navigation.NavigateTo("/beneficiary/withdrawals");
        }
        catch (Exception ex)
        {
            withdrawalErrorMessage = $"No se pudo registrar la solicitud de retiro: {ex.Message}";
        }
        finally
        {
            isSubmittingWithdrawal = false;
        }
    }

    private async Task LoadWithdrawalStateAsync()
    {
        if (activeCase is null || currentUserId <= 0)
        {
            availableBalance = 0;
            canRequestWithdrawal = false;
            withdrawalHelperText = "No se encontro informacion suficiente para procesar retiros.";
            return;
        }

        availableBalance = await RetiroService.ObtenerBalanceDisponibleAsync(activeCase.Id);

        var withdrawals = await RetiroService.ObtenerPorBeneficiadoIdAsync(currentUserId);
        hasPendingWithdrawalRequest = withdrawals.Any(r =>
            r.IdCaso == activeCase.Id &&
            string.Equals(r.Estado, "Pendiente", StringComparison.OrdinalIgnoreCase));

        canRequestWithdrawal = availableBalance > 0 && !hasPendingWithdrawalRequest;
        withdrawalHelperText = BuildWithdrawalHelperText();
    }

    private string BuildWithdrawalHelperText()
    {
        if (hasPendingWithdrawalRequest)
        {
            return "Ya existe una solicitud de retiro pendiente para este caso.";
        }

        if (availableBalance <= 0)
        {
            return "Aun no tienes fondos disponibles para retirar.";
        }

        return "Elige el monto y el metodo de retiro para enviar tu solicitud.";
    }

    private string BuildPaymentDetails()
    {
        if (IsTransferPaymentMethod)
        {
            return string.Create(
                CultureInfo.InvariantCulture,
                $"Titular={NormalizePaymentValue(WithdrawalForm.AccountHolderName)};Cuenta={NormalizePaymentValue(WithdrawalForm.AccountNumber)};Banco={NormalizePaymentValue(WithdrawalForm.BankName)}");
        }

        return NormalizePaymentValue(WithdrawalForm.PayPalEmail);
    }

    private static string NormalizePaymentValue(string? value)
    {
        return string.Join(" ", (value ?? string.Empty)
            .Trim()
            .Split(' ', StringSplitOptions.RemoveEmptyEntries));
    }

    private sealed class WithdrawalRequestModel : IValidatableObject
    {
        [Required(ErrorMessage = "El monto es obligatorio.")]
        [Range(typeof(decimal), "0.01", "999999999", ErrorMessage = "Ingresa un monto valido.")]
        public decimal Amount { get; set; }

        [Required(ErrorMessage = "Selecciona un metodo de retiro.")]
        public string PaymentMethod { get; set; } = string.Empty;

        [StringLength(120, ErrorMessage = "El nombre del titular no puede exceder 120 caracteres.")]
        public string AccountHolderName { get; set; } = string.Empty;

        [StringLength(60, ErrorMessage = "El numero de cuenta no puede exceder 60 caracteres.")]
        public string AccountNumber { get; set; } = string.Empty;

        [StringLength(100, ErrorMessage = "El nombre del banco no puede exceder 100 caracteres.")]
        public string BankName { get; set; } = string.Empty;

        [StringLength(255, ErrorMessage = "El correo de PayPal no puede exceder 255 caracteres.")]
        public string PayPalEmail { get; set; } = string.Empty;

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            if (string.Equals(PaymentMethod, "Transferencia", StringComparison.OrdinalIgnoreCase))
            {
                if (string.IsNullOrWhiteSpace(AccountHolderName))
                {
                    yield return new ValidationResult("El nombre del titular es obligatorio.", new[] { nameof(AccountHolderName) });
                }

                if (string.IsNullOrWhiteSpace(AccountNumber))
                {
                    yield return new ValidationResult("El numero de cuenta es obligatorio.", new[] { nameof(AccountNumber) });
                }

                if (string.IsNullOrWhiteSpace(BankName))
                {
                    yield return new ValidationResult("El banco es obligatorio.", new[] { nameof(BankName) });
                }

                var transferDetailsLength =
                    $"Titular={NormalizePaymentValue(AccountHolderName)};Cuenta={NormalizePaymentValue(AccountNumber)};Banco={NormalizePaymentValue(BankName)}".Length;

                if (transferDetailsLength > MaxPaymentDetailsLength)
                {
                    yield return new ValidationResult(
                        "Los datos bancarios son demasiado largos para registrarse. Acorta el nombre del titular o el nombre del banco.",
                        new[] { nameof(AccountHolderName), nameof(BankName) });
                }
            }
            else if (string.Equals(PaymentMethod, "PayPal", StringComparison.OrdinalIgnoreCase))
            {
                if (string.IsNullOrWhiteSpace(PayPalEmail))
                {
                    yield return new ValidationResult("El correo de PayPal es obligatorio.", new[] { nameof(PayPalEmail) });
                }
                else if (!new EmailAddressAttribute().IsValid(PayPalEmail))
                {
                    yield return new ValidationResult("Ingresa un correo de PayPal valido.", new[] { nameof(PayPalEmail) });
                }
            }
        }
    }
}
