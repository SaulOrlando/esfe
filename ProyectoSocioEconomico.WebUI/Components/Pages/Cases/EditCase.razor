@namespace ProyectoSocioEconomico.WebUI.Components.Pages
@page "/cases/{Id:int}/edit"
@page "/cases/edit/{Id:int}"
@*
  EditCase.razor
  Proposito: Pagina para editar o eliminar un caso existente.
*@
@layout EmptyLayout
@rendermode InteractiveServer
@using ProyectoSocioEconomico.Application.Interfaces
@using ProyectoSocioEconomico.Domain.Entities
@using ProyectoSocioEconomico.WebUI.Services
@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@inject ICasoService CasoService
@inject CustomAuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation

<div class="ec-page">
    @if (IsLoading)
    {
        <div class="ec-page-header">
            <div class="ec-page-header__left">
                <h1 class="ec-page-header__title">Cargando caso...</h1>
                <p class="ec-page-header__subtitle">Estamos preparando la informacion para edicion.</p>
            </div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(ErrorMessage) && FormModel is null)
    {
        <section class="ec-card ec-card--message">
            <h1 class="ec-page-header__title">No se pudo cargar el caso</h1>
            <p class="ec-page-header__subtitle">@ErrorMessage</p>
            <a href="/beneficiary/dashboard" class="ec-btn-back">Volver a mi caso</a>
        </section>
    }
    else if (FormModel is not null)
    {
        <div class="ec-page-header">
            <div class="ec-page-header__left">
                <h1 class="ec-page-header__title">Editar caso</h1>
                <p class="ec-page-header__subtitle">Actualice la informacion principal de su caso y guarde los cambios.</p>
            </div>
            <div class="ec-status-badge">
                <span class="ec-status-badge__icon"><i class="fas fa-folder-open"></i></span>
                <span class="ec-status-badge__label">ESTADO:</span>
                <span class="ec-status-badge__value">@CurrentCase?.Estado</span>
            </div>
        </div>

        <EditForm Model="FormModel" OnValidSubmit="HandleUpdateAsync" FormName="EditCaseForm">
            <DataAnnotationsValidator />

            <div class="ec-body">
                <div class="ec-main">
                    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
                    {
                        <div class="bulma-notification bulma-is-danger bulma-is-light">@ErrorMessage</div>
                    }

                    @if (!string.IsNullOrWhiteSpace(StatusMessage))
                    {
                        <div class="bulma-notification bulma-is-success bulma-is-light">@StatusMessage</div>
                    }

                    <section class="ec-card">
                        <h2 class="ec-card__title">
                            <span class="ec-card__title-icon ec-card__title-icon--yellow">
                                <i class="fas fa-pen-to-square"></i>
                            </span>
                            Informacion general
                        </h2>

                        <div class="ec-form-grid ec-form-grid--2col">
                            <div class="bulma-field ec-field">
                                <label class="bulma-label ec-label" for="case-title">Titulo del caso</label>
                                <div class="bulma-control ec-control">
                                    <InputText id="case-title" class="bulma-input ec-input" @bind-Value="FormModel.CaseTitle" />
                                </div>
                                <ValidationMessage For="@(() => FormModel.CaseTitle)" class="bulma-help bulma-is-danger" />
                            </div>

                            <div class="bulma-field ec-field">
                                <label class="bulma-label ec-label" for="category">Categoria</label>
                                <div class="bulma-control ec-control">
                                    <div class="bulma-select bulma-is-fullwidth ec-select-wrap">
                                        <InputSelect id="category" class="ec-select" @bind-Value="FormModel.CategoryId">
                                            <option value="">Seleccione una categoria</option>
                                            @foreach (var category in Categories)
                                            {
                                                <option value="@category.Id">@category.Nombre</option>
                                            }
                                        </InputSelect>
                                    </div>
                                </div>
                                <ValidationMessage For="@(() => FormModel.CategoryId)" class="bulma-help bulma-is-danger" />
                            </div>
                        </div>

                        <div class="bulma-field ec-field ec-field--full">
                            <label class="bulma-label ec-label" for="description">Descripcion detallada</label>
                            <div class="bulma-control ec-control">
                                <InputTextArea id="description"
                                               class="bulma-textarea ec-textarea"
                                               rows="7"
                                               @bind-Value="FormModel.Description" />
                            </div>
                            <ValidationMessage For="@(() => FormModel.Description)" class="bulma-help bulma-is-danger" />
                            <p class="ec-char-count">Palabras: @WordCount/@MaxWords</p>
                        </div>
                    </section>

                    <section class="ec-card">
                        <h2 class="ec-card__title">
                            <span class="ec-card__title-icon ec-card__title-icon--yellow">
                                <i class="fas fa-hand-holding-dollar"></i>
                            </span>
                            Meta de recaudacion
                        </h2>

                        <div class="bulma-field ec-field ec-field--narrow">
                            <label class="bulma-label ec-label" for="amount">Monto meta</label>
                            <div class="bulma-control ec-control">
                                <div class="ec-money-wrap ec-money-wrap--disabled">
                                    <span class="ec-money-prefix">$</span>
                                    <InputNumber id="amount"
                                                 class="bulma-input ec-input ec-input--money"
                                                 @bind-Value="FormModel.RequiredAmount"
                                                 disabled />
                                </div>
                            </div>
                            <p class="ec-field-note">La meta es solo informativa y no puede editarse desde esta pantalla.</p>
                        </div>
                    </section>

                    <section class="ec-card">
                        <h2 class="ec-card__title">
                            <span class="ec-card__title-icon ec-card__title-icon--yellow">
                                <i class="fas fa-circle-info"></i>
                            </span>
                            Informacion adicional
                        </h2>

                        <div class="ec-summary-grid">
                            <article class="ec-summary-item">
                                <span class="ec-summary-item__label">Fecha de creacion</span>
                                <strong class="ec-summary-item__value">@CurrentCase?.FechaCreacion.ToString("dd/MM/yyyy")</strong>
                            </article>
                            <article class="ec-summary-item">
                                <span class="ec-summary-item__label">Categoria actual</span>
                                <strong class="ec-summary-item__value">@CurrentCase?.IdCategoriaNavigation?.Nombre</strong>
                            </article>
                            <article class="ec-summary-item">
                                <span class="ec-summary-item__label">Estado del caso</span>
                                <strong class="ec-summary-item__value">@CurrentCase?.Estado</strong>
                            </article>
                        </div>
                    </section>

                    <section class="ec-card">
                        <h2 class="ec-card__title">
                            <span class="ec-card__title-icon ec-card__title-icon--yellow">
                                <i class="fas fa-trash"></i>
                            </span>
                            Borrar caso
                        </h2>

                        <p class="ec-field-note">Esta accion elimina el caso de forma permanente. Si el caso ya tiene donaciones o retiros registrados, el borrado sera bloqueado.</p>

                        @if (ShowDeleteConfirmation)
                        {
                            <div class="bulma-notification bulma-is-danger bulma-is-light">
                                <p>Confirme si desea borrar este caso.</p>
                                <div class="ec-action-bar" style="margin-top: 1rem;">
                                    <button type="button" class="ec-action-bar__cancel" @onclick="CancelDelete" disabled="@IsDeleting">Cancelar</button>
                                    <button type="button" class="bulma-button bulma-is-danger" @onclick="HandleDeleteAsync" disabled="@IsDeleting">
                                        <span class="bulma-icon bulma-is-small"><i class="fas fa-trash"></i></span>
                                        <strong>@(IsDeleting ? "Borrando..." : "Confirmar borrado")</strong>
                                    </button>
                                </div>
                            </div>
                        }
                    </section>
                </div>

                <aside class="ec-sidebar">
                    <div class="ec-tips-card">
                        <h3 class="ec-tips-card__title">
                            <span class="ec-tips-card__icon"><i class="far fa-lightbulb"></i></span>
                            Recomendaciones
                        </h3>
                        <ol class="ec-tips-list">
                            <li class="ec-tips-list__item">
                                <span class="ec-tips-list__num">1</span>
                                <div>
                                    <strong>Sea claro:</strong>
                                    <p>Explique con precision en que se utilizara la ayuda para generar mas confianza.</p>
                                </div>
                            </li>
                            <li class="ec-tips-list__item">
                                <span class="ec-tips-list__num">2</span>
                                <div>
                                    <strong>Evite duplicidad:</strong>
                                    <p>Mantenga el mensaje enfocado en la necesidad principal del caso.</p>
                                </div>
                            </li>
                            <li class="ec-tips-list__item">
                                <span class="ec-tips-list__num">3</span>
                                <div>
                                    <strong>Revise redaccion:</strong>
                                    <p>Un texto bien escrito facilita la comprension para donantes y administradores.</p>
                                </div>
                            </li>
                        </ol>
                    </div>
                </aside>
            </div>

            <div class="ec-action-bar">
                <button type="button" class="ec-action-bar__cancel" @onclick="HandleCancel" disabled="@IsSaving || IsDeleting">Cancelar</button>
                <button type="button" class="bulma-button bulma-is-danger bulma-is-light" @onclick="StartDelete" disabled="@IsSaving || IsDeleting">
                    <span class="bulma-icon bulma-is-small"><i class="fas fa-trash"></i></span>
                    <strong>Borrar caso</strong>
                </button>
                <button type="submit" class="bulma-button bulma-is-warning ec-btn-update" disabled="@IsSaving || IsDeleting">
                    <span class="bulma-icon bulma-is-small"><i class="fas fa-floppy-disk"></i></span>
                    <strong>@(IsSaving ? "Actualizando..." : "Actualizar caso")</strong>
                </button>
            </div>
        </EditForm>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private const int MaxWords = 500;

    private Caso? CurrentCase { get; set; }
    private EditCaseModel? FormModel { get; set; }
    private List<Categoria> Categories { get; set; } = new();
    private bool IsLoading { get; set; } = true;
    private bool IsSaving { get; set; }
    private bool IsDeleting { get; set; }
    private bool ShowDeleteConfirmation { get; set; }
    private string? ErrorMessage { get; set; }
    private string? StatusMessage { get; set; }

    private int WordCount => string.IsNullOrWhiteSpace(FormModel?.Description)
        ? 0
        : FormModel.Description.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries).Length;

    protected override async Task OnInitializedAsync()
    {
        await LoadPageAsync();
    }

    private async Task LoadPageAsync()
    {
        try
        {
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity is null || !user.Identity.IsAuthenticated)
            {
                Navigation.NavigateTo("/");
                return;
            }

            var userIdStr = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (!int.TryParse(userIdStr, out var userId))
            {
                Navigation.NavigateTo("/");
                return;
            }

            Categories = await CasoService.ObtenerCategorias();
            CurrentCase = await CasoService.ObtenerPorIdConDetallesAsync(Id);

            if (CurrentCase is null || CurrentCase.IdBeneficiado != userId)
            {
                ErrorMessage = "No se encontro el caso solicitado o no tiene permisos para editarlo.";
                return;
            }

            FormModel = new EditCaseModel
            {
                CaseTitle = CurrentCase.Titulo,
                CategoryId = CurrentCase.IdCategoria,
                Description = CurrentCase.Descripcion,
                RequiredAmount = CurrentCase.Meta
            };
        }
        catch (Exception ex)
        {
            ErrorMessage = "Ocurrio un error al cargar el caso: " + ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void HandleCancel()
    {
        Navigation.NavigateTo("/beneficiary/dashboard");
    }

    private void StartDelete()
    {
        ErrorMessage = null;
        StatusMessage = null;
        ShowDeleteConfirmation = true;
    }

    private void CancelDelete()
    {
        ShowDeleteConfirmation = false;
    }

    private async Task HandleUpdateAsync()
    {
        if (FormModel is null || CurrentCase is null)
        {
            return;
        }

        ErrorMessage = null;
        StatusMessage = null;
        IsSaving = true;

        try
        {
            CurrentCase.Titulo = FormModel.CaseTitle.Trim();
            CurrentCase.Descripcion = FormModel.Description.Trim();
            CurrentCase.IdCategoria = FormModel.CategoryId ?? CurrentCase.IdCategoria;

            await CasoService.Actualizar(CurrentCase);
            Navigation.NavigateTo("/beneficiary/dashboard");
        }
        catch (Exception ex)
        {
            ErrorMessage = "No se pudo actualizar el caso: " + ex.Message;
        }
        finally
        {
            IsSaving = false;
        }
    }

    private async Task HandleDeleteAsync()
    {
        if (CurrentCase is null)
        {
            return;
        }

        ErrorMessage = null;
        StatusMessage = null;
        IsDeleting = true;

        try
        {
            await CasoService.EliminarAsync(CurrentCase.Id);
            Navigation.NavigateTo("/beneficiary/dashboard");
        }
        catch (Exception ex)
        {
            ErrorMessage = "No se pudo borrar el caso: " + ex.Message;
        }
        finally
        {
            IsDeleting = false;
            ShowDeleteConfirmation = false;
        }
    }

    private sealed class EditCaseModel
    {
        [Required(ErrorMessage = "El titulo es obligatorio.")]
        [StringLength(120, ErrorMessage = "El titulo no puede exceder 120 caracteres.")]
        public string CaseTitle { get; set; } = string.Empty;

        [Required(ErrorMessage = "Seleccione una categoria.")]
        public int? CategoryId { get; set; }

        [Required(ErrorMessage = "La descripcion es obligatoria.")]
        [StringLength(3000, ErrorMessage = "La descripcion no puede exceder 3000 caracteres.")]
        public string Description { get; set; } = string.Empty;

        public decimal RequiredAmount { get; set; }
    }
}
