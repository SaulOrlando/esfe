@*
  CardsComponent.razor
  Propósito: Componente que muestra hasta 4 programas activos recientes en la página principal.
  Recupera los programas a través de `IProgramaService`.
*@
@using ProyectoSocioEconomico.Application.Interfaces
@using ProyectoSocioEconomico.Domain.Entities
@inject IProgramaService ProgramaService

<section class="bulma-section">
    <div class="bulma-container">
        @if (Programs.Count == 0)
        {
            <div class="bulma-notification bulma-is-light">
                <p class="bulma-has-text-grey">No hay programas disponibles por el momento.</p>
            </div>
        }
        else
        {
            <div class="programs-home-grid">
                @foreach (var program in Programs)
                {
                    <ProgramCardComponent @key="program.Id"
                                          Id="@program.Id"
                                          Title="@program.Nombre"
                                          Description="@program.Descripcion"
                                          Category="@GetCategoryName(program)"
                                          ProgressLabel="@GetProgressLabel(program)"
                                          Progress="@CalculateOverallProgress(program)"
                                          ImageUrl="@program.ImagenUrl"
                                          Compact="true" />
                }
            </div>
        }
    </div>
</section>

@code {
    private List<Programa> Programs { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        Programs = (await ProgramaService.ObtenerPublicosConCasosAsync())
            .OrderByDescending(program => program.FechaCreacion)
            .Take(4)
            .ToList();
    }

    private static string GetCategoryName(Programa program)
    {
        return program.IdCategoriaNavigation?.Nombre ?? "Otro";
    }

    private static string GetProgressLabel(Programa program)
    {
        if (SupportsVolunteerGoal(program) && !SupportsFinancialGoal(program))
        {
            return "Voluntarios";
        }

        if (SupportsVolunteerGoal(program) && SupportsFinancialGoal(program))
        {
            return "Meta financiera";
        }

        return "Meta";
    }

    private static int CalculateOverallProgress(Programa program)
    {
        if (SupportsVolunteerGoal(program) && !SupportsFinancialGoal(program))
        {
            var totalVoluntarios = program.InscripcionesVoluntarios?
                .Count(i =>
                    string.Equals(i.Estado, "Aprobado", StringComparison.OrdinalIgnoreCase) ||
                    string.Equals(i.Estado, "Activo", StringComparison.OrdinalIgnoreCase)) ?? 0;

            if (program.MetaVoluntarios <= 0)
            {
                return 0;
            }

            return Math.Clamp((int)Math.Round((decimal)totalVoluntarios / program.MetaVoluntarios * 100), 0, 100);
        }

        var totalRecaudado = program.Donaciones?
            .Where(d => d.Estado == "Completado")
            .Sum(d => d.Monto) ?? 0m;

        if (program.MetaFinanciera <= 0)
        {
            return 0;
        }

        return Math.Clamp((int)Math.Round((totalRecaudado / program.MetaFinanciera) * 100), 0, 100);
    }

    private static bool SupportsFinancialGoal(Programa program)
    {
        return string.Equals(program.TipoPrograma, "Financiero", StringComparison.OrdinalIgnoreCase) ||
               string.Equals(program.TipoPrograma, "Hibrido", StringComparison.OrdinalIgnoreCase);
    }

    private static bool SupportsVolunteerGoal(Programa program)
    {
        return string.Equals(program.TipoPrograma, "Voluntariado", StringComparison.OrdinalIgnoreCase) ||
               string.Equals(program.TipoPrograma, "Hibrido", StringComparison.OrdinalIgnoreCase);
    }
}
