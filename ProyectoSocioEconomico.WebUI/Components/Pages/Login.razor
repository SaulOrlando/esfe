@page "/login"

<form>
    <div class="login-step3">
        <section class="bulma-container login-step3-container">
            <section class="bulma-section login-step3-section bulma-has-text-black">
                <div class="login-step3-text">
                    <h1 class="bulma-title bulma-has-text-black">Seguridada y configuracion de la cuenta</h1>
                    <p>Finalize your credentials and select your role within the community.</p>
                </div>
                <section class="login-step3-inputs">
                    <label class="item">
                        <span>Correo electronico</span>
                        <div class="bulma-control bulma-has-icons-right">
                            <input
                            class="bulma-input bulma-input-rounded bulma-is-medium"
                            type="email" name="email" placeholder="ejemplo@gmail.com" />
                            <span class="bulma-icon bulma-is-small bulma-is-right">
                                <i class="fa-solid fa-at"></i>
                            </span>
                        </div>
                    </label>
                    <section class="login-step3-inputs-passwords">
                        @* <div class="bulma-control bulma-has-icons-left "> *@
                        <label>
                            <span>Contraseña</span>
                            <div class="bulma-control">
                                <input
                                class="bulma-input bulma-input-rounded  bulma-is-medium"
                                type="text" name="password" placeholder="Introduce tu contraseña" />
                                @* <span class="bulma-icon bulma-is-small bulma-is-left">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </span> *@
                            </div>
                        </label>
                        @* <div class="bulma-control bulma-has-icons-left "> *@
                        <label>
                            <span>Repite la contraña</span>
                            <div class="bulma-control  ">
                                <input
                                class="bulma-input bulma-input-rounded bulma-is-medium "
                                type="password" name="repeatPassword"
                                placeholder="Introduce tu constraseña de nuevo" />
                                @* <span class="bulma-icon bulma-is-small bulma-is-left">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </span>*@
                            </div>
                        </label>
                    </section>
                </section>
                <div class="bulma-is-flex">
                    <label class="checkbox">
                        <input type="checkbox" class="mr-5"/>
                        <span class="bulma-has-text-centred bulma-has-text-black">I agree to the Terms of Service and Privacy
                        Policy. I understand that my data will be
                        used for socioeconomic analysis.</span>
                    </label>
                </div>
                    <button type="submit" class="bulma-button bulma-is-warning bulma-is-fullwidth">Crear Cuenta</button>
                </section>
            </section>
        </div>
    </form>